<section class="search-results-section">
  <style>
    .search-results-section {
      padding: 120px 24px 60px;
      max-width: 1200px;
      margin: 0 auto;
      min-height: 60vh;
    }

    .search-header {
      text-align: center;
      margin-bottom: 48px;
    }

    .search-title {
      font-size: 2.5rem;
      font-weight: 800;
      margin-bottom: 16px;
      background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .search-query {
      color: var(--color-primary);
      font-weight: 700;
    }

    .search-count {
      font-size: 1.125rem;
      color: var(--color-text-subdued);
    }

    .search-suggestions {
      margin-top: 16px;
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 8px;
      align-items: center;
    }

    .search-suggestions-label {
      font-size: 13px;
      color: var(--color-text-subdued);
      margin-right: 4px;
    }

    .search-suggestion-tag {
      padding: 4px 12px;
      background: var(--color-bg-card);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-full);
      font-size: 12px;
      color: var(--color-text);
      text-decoration: none;
      transition: all 0.2s ease;
    }

    .search-suggestion-tag:hover {
      border-color: var(--color-primary);
      color: var(--color-primary);
    }

    .search-filters {
      display: flex;
      justify-content: center;
      gap: 12px;
      margin-bottom: 32px;
      flex-wrap: wrap;
    }

    .search-filter-btn {
      padding: 10px 24px;
      border-radius: var(--radius-full);
      background: var(--color-bg-card);
      border: 1px solid var(--color-border);
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      color: var(--color-text);
    }

    .search-filter-btn:hover {
      border-color: var(--color-primary);
      color: var(--color-primary);
    }

    .search-filter-btn.active {
      background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
      border-color: transparent;
      color: white;
      box-shadow: var(--shadow-glow);
    }

    .search-filter-count {
      display: inline-block;
      margin-left: 6px;
      padding: 2px 8px;
      background: rgba(255, 255, 255, 0.2);
      border-radius: 10px;
      font-size: 11px;
      font-weight: 700;
    }

    .search-section {
      margin-bottom: 48px;
    }

    .search-section[hidden] {
      display: none;
    }

    .search-section-title {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 20px;
      color: var(--color-text);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .search-section-count {
      font-size: 14px;
      color: var(--color-text-subdued);
      font-weight: 500;
    }

    .search-collections-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    .search-collection-card {
      background: var(--color-bg-card);
      border-radius: var(--radius-xl);
      overflow: hidden;
      border: 1px solid var(--color-border);
      transition: all 0.3s ease;
      display: flex;
      flex-direction: column;
      height: 100%;
      text-decoration: none;
    }

    .search-collection-card:hover {
      transform: translateY(-8px);
      box-shadow: var(--shadow-lg), var(--shadow-glow);
      border-color: var(--color-primary);
    }

    .search-collection-image-wrapper {
      width: 100%;
      height: 180px;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--color-bg);
      flex-shrink: 0;
    }

    .search-collection-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.3s ease;
    }

    .search-collection-card:hover .search-collection-image {
      transform: scale(1.05);
    }

    .search-collection-info {
      padding: 16px;
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
    }

    .search-collection-title {
      font-size: 16px;
      font-weight: 700;
      color: var(--color-text);
      margin-bottom: 4px;
    }

    .search-collection-count {
      font-size: 13px;
      color: var(--color-text-subdued);
    }

    .search-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
    }

    .search-card {
      background: var(--color-bg-card);
      border-radius: var(--radius-xl);
      overflow: hidden;
      border: 1px solid var(--color-border);
      transition: all 0.3s ease;
      display: flex;
      flex-direction: column;
      height: 100%;
      text-decoration: none;
    }

    .search-card:hover {
      transform: translateY(-8px);
      box-shadow: var(--shadow-lg), var(--shadow-glow);
      border-color: var(--color-primary);
    }

    .search-card-image-wrapper {
      width: 100%;
      height: 220px;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--color-bg);
      flex-shrink: 0;
    }

    .search-card-image {
      width: 100%;
      height: 100%;
      object-fit: contain;
      transition: transform 0.3s ease;
    }

    .search-card:hover .search-card-image {
      transform: scale(1.05);
    }

    .search-card-info {
      padding: 16px;
      display: flex;
      flex-direction: column;
      margin-top: auto;
      flex-shrink: 0;
    }

    .search-card-title {
      font-size: 14px;
      font-weight: 600;
      color: var(--color-text);
      display: block;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      margin-bottom: 8px;
      line-height: 1.4;
    }

    .search-card-price {
      font-size: 16px;
      font-weight: 700;
      color: var(--color-primary);
      margin-top: auto;
    }

    .no-results {
      text-align: center;
      padding: 80px 24px;
    }

    .no-results-icon {
      font-size: 4rem;
      margin-bottom: 24px;
      opacity: 0.5;
    }

    .no-results-title {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 16px;
    }

    .no-results-text {
      font-size: 1rem;
      color: var(--color-text-subdued);
      margin-bottom: 24px;
    }

    .no-results-btn {
      padding: 14px 32px;
      border-radius: var(--radius-full);
      background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
      font-size: 14px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      transition: all 0.3s ease;
      text-decoration: none;
      color: white;
      display: inline-block;
    }

    .no-results-btn:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-glow);
    }

    @media (max-width: 992px) {
      .search-grid {
        grid-template-columns: repeat(3, 1fr);
      }

      .search-collections-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 768px) {
      .search-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .search-collections-grid {
        grid-template-columns: 1fr;
      }

      .search-title {
        font-size: 1.75rem;
      }

      .search-card-image-wrapper {
        height: 180px;
      }
    }

    @media (max-width: 480px) {
      .search-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  {% assign products_count = 0 %}
  {% assign collections_count = 0 %}
  {% assign articles_count = 0 %}
  {% assign pages_count = 0 %}
  {% for item in search.results %}
    {% if item.object_type == 'collection' %}
      {% assign collections_count = collections_count | plus: 1 %}
    {% elsif item.object_type == 'article' %}
      {% assign articles_count = articles_count | plus: 1 %}
    {% elsif item.object_type == 'page' %}
      {% assign pages_count = pages_count | plus: 1 %}
    {% else %}
      {% assign products_count = products_count | plus: 1 %}
    {% endif %}
  {% endfor %}
  {% assign total_count = products_count | plus: collections_count | plus: articles_count | plus: pages_count %}

  <div class="search-header">
    <h1 class="search-title">
      Search Results for "<span class="search-query">{{ search.terms }}</span>"
    </h1>
    <p class="search-count" id="searchCount">
      <span id="totalCount">{{ total_count }}</span> results found
      {% if products_count > 0 %}({{ products_count }} products, {{ collections_count }} collections){% endif %}
    </p>
    {% if search.terms != blank %}
    <div class="search-suggestions">
      <span class="search-suggestions-label">Try:</span>
      <a href="/search?q=Naruto" class="search-suggestion-tag">Naruto</a>
      <a href="/search?q=One+Piece" class="search-suggestion-tag">One Piece</a>
      <a href="/search?q=Dragon+Ball" class="search-suggestion-tag">Dragon Ball</a>
      <a href="/search?q=Marvel" class="search-suggestion-tag">Marvel</a>
    </div>
    {% endif %}
  </div>

  <div class="search-filters" id="searchFilters">
    <button class="search-filter-btn active" data-filter="all">
      All <span class="search-filter-count">{{ total_count }}</span>
    </button>
    {% if products_count > 0 %}
    <button class="search-filter-btn" data-filter="products">
      Products <span class="search-filter-count">{{ products_count }}</span>
    </button>
    {% endif %}
    {% if collections_count > 0 %}
    <button class="search-filter-btn" data-filter="collections">
      Collections <span class="search-filter-count">{{ collections_count }}</span>
    </button>
    {% endif %}
    {% if articles_count > 0 %}
    <button class="search-filter-btn" data-filter="articles">
      Articles <span class="search-filter-count">{{ articles_count }}</span>
    </button>
    {% endif %}
    {% if pages_count > 0 %}
    <button class="search-filter-btn" data-filter="pages">
      Pages <span class="search-filter-count">{{ pages_count }}</span>
    </button>
    {% endif %}
  </div>

  {% if collections_count > 0 %}
    <div class="search-section" data-section="collections" id="collectionsSection">
      <h3 class="search-section-title">
        Collections
        <span class="search-section-count">({{ collections_count }})</span>
      </h3>
      <div class="search-collections-grid">
        {% for item in search.results %}
          {% if item.object_type == 'collection' %}
            <a href="{{ item.url }}" class="search-collection-card">
              <div class="search-collection-image-wrapper">
                {% if item.image %}
                  <img src="{{ item.image.src | img_url: '800x600' }}" alt="{{ item.title }}" class="search-collection-image" loading="lazy">
                {% endif %}
              </div>
              <div class="search-collection-info">
                <span class="search-collection-title">{{ item.title }}</span>
                <span class="search-collection-count">{{ item.products_count }} products</span>
              </div>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% if products_count > 0 %}
    <div class="search-section" data-section="products" id="productsSection">
      <h3 class="search-section-title">
        Products
        <span class="search-section-count">({{ products_count }})</span>
      </h3>
      <div class="search-grid">
        {% for item in search.results %}
          {% if item.object_type != 'collection' and item.object_type != 'article' and item.object_type != 'page' %}
            <a href="{{ item.url }}" class="search-card">
              <div class="search-card-image-wrapper">
                {% if item.featured_image %}
                  <img src="{{ item.featured_image.src | img_url: '500x667' }}" alt="{{ item.title }}" class="search-card-image" loading="lazy">
                {% endif %}
              </div>
              <div class="search-card-info">
                <span class="search-card-title">{{ item.title }}</span>
                <span class="search-card-price">{{ item.price | money }}</span>
              </div>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  {% endif %}

  {% if total_count == 0 %}
    <div class="no-results">
      <div class="no-results-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.35-4.35"></path>
        </svg>
      </div>
      <h2 class="no-results-title">No results found for "{{ search.terms }}"</h2>
      <p class="no-results-text">Try different keywords or browse our popular series below.</p>
      <a href="/collections/all" class="no-results-btn">Browse All Products</a>
    </div>
  {% endif %}

  <script>
    (function() {
      const filterBtns = document.querySelectorAll('.search-filter-btn');
      const sections = document.querySelectorAll('.search-section');
      const totalCountEl = document.getElementById('totalCount');
      const searchCountEl = document.getElementById('searchCount');

      if (!filterBtns.length) return;

      filterBtns.forEach(btn => {
        btn.addEventListener('click', function() {
          filterBtns.forEach(b => b.classList.remove('active'));
          this.classList.add('active');
          
          const filter = this.dataset.filter;
          let visibleCount = 0;
          
          sections.forEach(section => {
            const sectionType = section.dataset.section;
            if (filter === 'all') {
              section.hidden = false;
              visibleCount += parseInt(section.querySelector('.search-section-count')?.textContent.replace(/[^\d]/g, '') || 0);
            } else if (sectionType === filter) {
              section.hidden = false;
              visibleCount += parseInt(section.querySelector('.search-section-count')?.textContent.replace(/[^\d]/g, '') || 0);
            } else {
              section.hidden = true;
            }
          });
          
          if (totalCountEl) {
            totalCountEl.textContent = visibleCount;
          }
          
          if (searchCountEl) {
            const resultText = visibleCount === 1 ? 'result' : 'results';
            searchCountEl.innerHTML = '<span id="totalCount">' + visibleCount + '</span> ' + resultText + ' found';
          }
          
          window.scrollTo({
            top: document.querySelector('.search-results-section').offsetTop - 100,
            behavior: 'smooth'
          });
        });
      });
    })();
  </script>
</section>
