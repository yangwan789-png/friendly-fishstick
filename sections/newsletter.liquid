<section class="newsletter-section">
  <div class="newsletter-card">
    <div class="newsletter-card__icon">📧</div>
    <h2 class="newsletter-card__title">Join Our Anime Community</h2>
    <p class="newsletter-card__description">Get exclusive discounts, new release alerts, and anime news delivered to your inbox.</p>
    <form class="newsletter-form" action="/contact" method="post">
      <input type="email" class="newsletter-form__input" placeholder="Enter your email" required>
      <button type="submit" class="newsletter-form__button">Subscribe</button>
    </form>
  </div>
</section>
{% schema %}
{
  "name": "Newsletter",
  "settings": []
}
{% endschema %}