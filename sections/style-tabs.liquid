<section class="style-tabs">
  <div class="container">
    <h3 class="style-tabs__title">Art Styles</h3>
    <div class="style-tabs__list">
      <button class="style-tab__item {% unless current_tags contains 'Style_' %}active{% endunless %}" data-style="">
        All Styles
      </button>
      {% assign style_tags = collection.all_tags | where_exp: 'tag', 'tag contains 'Style'' %}
      {% for tag in style_tags %}
        {% assign style_name = tag | replace: 'Style_', '' %}
        <button class="style-tab__item {% if current_tags contains tag %}active{% endif %}" data-style="{{ tag }}">
          {{ style_name }}
        </button>
      {% endfor %}
    </div>
  </div>
</section>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const styleButtons = document.querySelectorAll('.style-tab__item');
    const collectionUrl = '{{ collection.url }}';
    
    styleButtons.forEach(button => {
      button.addEventListener('click', function() {
        const style = this.dataset.style;
        let url = collectionUrl;
        if (style) {
          url = `${collectionUrl}/${style}`;
        }
        window.location.href = url;
      });
    });
  });
</script>
{% schema %}
{
  "name": "Style Tabs",
  "settings": []
}
{% endschema %}