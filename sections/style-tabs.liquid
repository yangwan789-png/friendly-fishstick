<section class="style-tabs">
  <style>
    .style-tabs {
      padding: 32px 0;
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
    }

    .style-tabs .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .style-tabs__title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--color-text-subdued);
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 16px;
    }

    .style-tabs__list {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .style-tab__item {
      padding: 10px 20px;
      background: var(--color-bg-card);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-full);
      font-size: 13px;
      font-weight: 500;
      color: var(--color-text);
      cursor: pointer;
      transition: all 0.3s ease;
      white-space: nowrap;
    }

    .style-tab__item:hover {
      border-color: var(--color-secondary);
      color: var(--color-secondary);
    }

    .style-tab__item.active {
      background: linear-gradient(135deg, var(--color-secondary), #06b6d4);
      border-color: transparent;
      color: var(--color-bg);
      box-shadow: var(--shadow-glow-cyan);
    }

    @media (max-width: 768px) {
      .style-tabs {
        padding: 24px 0;
      }

      .style-tabs .container {
        padding: 0 16px;
      }

      .style-tab__item {
        padding: 8px 16px;
        font-size: 12px;
      }
    }
  </style>

  <div class="container">
    <h3 class="style-tabs__title">Art Styles</h3>
    <div class="style-tabs__list">
      <button class="style-tab__item active" data-style="">
        All Styles
      </button>
      <button class="style-tab__item" data-style="realistic">
        Realistic
      </button>
      <button class="style-tab__item" data-style="anime">
        Anime
      </button>
      <button class="style-tab__item" data-style="chibi">
        Chibi
      </button>
      <button class="style-tab__item" data-style="cyberpunk">
        Cyberpunk
      </button>
      <button class="style-tab__item" data-style="watercolor">
        Watercolor
      </button>
      <button class="style-tab__item" data-style="minimalist">
        Minimalist
      </button>
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const styleButtons = document.querySelectorAll('.style-tab__item');
      
      styleButtons.forEach(button => {
        button.addEventListener('click', function() {
          styleButtons.forEach(btn => btn.classList.remove('active'));
          this.classList.add('active');
          
          const style = this.dataset.style;
          const products = document.querySelectorAll('.product-card');
          
          products.forEach(product => {
            if (!style || product.dataset.style === style) {
              product.style.display = '';
            } else {
              product.style.display = 'none';
            }
          });
        });
      });
    });
  </script>
</section>
{% schema %}
{
  "name": "Style Tabs",
  "settings": []
}
{% endschema %}