<section class="hero-section">
  {% for block in section.blocks %}
    <div class="hero-content">
      {% if block.settings.headline != blank %}
        <p class="hero-content__pre-title">Premium Anime Art</p>
        <h1 class="hero-content__title">
          <span class="hero-content__title-gradient">{{ block.settings.headline }}</span>
        </h1>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <p class="hero-content__subtitle">{{ block.settings.subheading }}</p>
      {% endif %}
      {% if block.settings.button_label != blank %}
        <div class="hero-content__buttons">
          <a href="{{ block.settings.button_link }}" class="btn btn-primary">
            {{ block.settings.button_label }}
            <span>→</span>
          </a>
          <a href="/collections/all" class="btn btn-secondary">
            View All Collections
          </a>
        </div>
      {% endif %}
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="hero-stat__value">1000+</div>
          <div class="hero-stat__label">Art Prints</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat__value">50+</div>
          <div class="hero-stat__label">Anime Series</div>
        </div>
        <div class="hero-stat">
          <div class="hero-stat__value">50K+</div>
          <div class="hero-stat__label">Happy Customers</div>
        </div>
      </div>
    </div>
  {% endfor %}
</section>
{% schema %}
{
  "name": "Slideshow",
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "text",
          "id": "headline",
          "label": "Headline"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button link"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "select",
      "id": "height",
      "label": "Height",
      "default": "large",
      "options": [
        {"value": "small", "label": "Small"},
        {"value": "medium", "label": "Medium"},
        {"value": "large", "label": "Large"}
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "Dark"
    }
  ],
  "presets": [
    {
      "name": "Slideshow",
      "blocks": [
        { "type": "slide" }
      ]
    }
  ]
}
{% endschema %}