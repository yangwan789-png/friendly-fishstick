<section class="hero">
  <style>
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
      padding: 80px 0 60px;
    }

    .hero-bg {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: var(--color-bg);
    }

    .hero-bg::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle at 20% 80%, rgba(255, 42, 109, 0.15) 0%, transparent 50%),
                  radial-gradient(circle at 80% 20%, rgba(5, 217, 232, 0.15) 0%, transparent 50%),
                  radial-gradient(circle at 50% 50%, rgba(168, 85, 247, 0.1) 0%, transparent 70%);
      animation: gradient-shift 20s ease infinite;
    }

    .hero-container {
      position: relative;
      z-index: 1;
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 24px;
      text-align: center;
    }

    .hero-badge {
      display: inline-block;
      padding: 8px 20px;
      background: rgba(255, 42, 109, 0.15);
      border: 1px solid rgba(255, 42, 109, 0.3);
      border-radius: var(--radius-full);
      font-size: 13px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--color-primary);
      margin-bottom: 24px;
      animation: pulse 3s ease-in-out infinite;
    }

    .hero-title {
      font-size: clamp(3rem, 8vw, 5.5rem);
      font-weight: 900;
      line-height: 1.1;
      margin-bottom: 24px;
      position: relative;
    }

    .hero-title-gradient {
      background: linear-gradient(135deg, var(--color-primary), var(--color-secondary), var(--color-accent));
      background-size: 200% 200%;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: gradient-shift 8s ease infinite;
    }

    .hero-subtitle {
      font-size: clamp(1.125rem, 3vw, 1.5rem);
      color: var(--color-text-subdued);
      max-width: 600px;
      margin: 0 auto 40px;
      line-height: 1.8;
    }

    .hero-stats {
      display: flex;
      justify-content: center;
      gap: 64px;
      margin-bottom: 48px;
      flex-wrap: wrap;
    }

    .stat-item {
      text-align: center;
    }

    .stat-number {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 900;
      background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      display: block;
    }

    .stat-label {
      font-size: 14px;
      color: var(--color-text-subdued);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-top: 8px;
    }

    .hero-buttons {
      display: flex;
      justify-content: center;
      gap: 16px;
      flex-wrap: wrap;
    }

    .hero-visual {
      margin-top: 60px;
      position: relative;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 16px;
      max-width: 900px;
      margin: 0 auto;
      align-items: stretch;
    }

    .hero-card {
      border-radius: var(--radius-xl);
      overflow: hidden;
      position: relative;
      transition: all 0.3s ease;
      cursor: pointer;
      background: var(--color-bg-card);
      display: flex;
      flex-direction: column;
      height: 100%;
    }

    .hero-card:hover {
      transform: translateY(-8px) scale(1.05);
      z-index: 10;
      box-shadow: var(--shadow-lg), var(--shadow-glow);
    }

    .hero-card-image-wrapper {
      width: 100%;
      height: 200px;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      background: var(--color-bg);
      flex-shrink: 0;
    }

    .hero-card-image {
      width: 100%;
      height: 100%;
      object-fit: contain;
      transition: transform 0.5s ease;
      display: block;
    }

    .hero-card:hover .hero-card-image {
      transform: scale(1.05);
    }

    .hero-card-info {
      position: relative;
      padding: 14px 16px;
      background: #16161d;
      border-top: 1px solid #2a2a35;
      min-height: 64px;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      margin-top: auto;
      flex-shrink: 0;
    }

    .hero-card-title {
      font-size: 13px;
      font-weight: 600;
      color: #ffffff;
      display: block;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      margin-bottom: 4px;
      line-height: 1.4;
      max-width: 100%;
    }

    .hero-card-price {
      font-size: 15px;
      font-weight: 700;
      color: #ff2a6d;
      display: block;
      line-height: 1.4;
    }

    .hero-card {
      animation: float 6s ease-in-out infinite;
    }
    .hero-card:nth-child(1) { animation-delay: 0s; }
    .hero-card:nth-child(2) { animation-delay: 0.5s; }
    .hero-card:nth-child(3) { animation-delay: 1s; }
    .hero-card:nth-child(4) { animation-delay: 1.5s; }
    .hero-card:nth-child(5) { animation-delay: 2s; }
    .hero-card:nth-child(6) { animation-delay: 2.5s; }
    .hero-card:nth-child(7) { animation-delay: 3s; }
    .hero-card:nth-child(8) { animation-delay: 3.5s; }

    @media (max-width: 768px) {
      .hero {
        min-height: auto;
        padding: 100px 0 40px;
      }

      .hero-title {
        font-size: clamp(2rem, 10vw, 3.5rem);
      }

      .hero-stats {
        gap: 32px;
      }

      .stat-number {
        font-size: clamp(1.5rem, 8vw, 2.5rem);
      }

      .hero-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
      }

      .hero-card-image-wrapper {
        height: 160px;
      }

      .hero-card {
        animation: none;
      }
    }
  </style>

  <div class="hero-bg"></div>
  <div class="hero-container">
    <span class="hero-badge">New Collection 2026</span>
    
    <h1 class="hero-title">
      <span class="hero-title-gradient">Anime Art</span>
      <br>
      <span class="hero-title-gradient">Prints</span>
    </h1>
    
    {% if section.settings.subtitle != blank %}
      <p class="hero-subtitle">{{ section.settings.subtitle }}</p>
    {% endif %}

    <div class="hero-stats">
      <div class="stat-item">
        <span class="stat-number">1000+</span>
        <span class="stat-label">Art Prints</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">50+</span>
        <span class="stat-label">Anime Series</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">50K+</span>
        <span class="stat-label">Happy Customers</span>
      </div>
    </div>

    <div class="hero-buttons">
      <a href="/collections/all" class="btn btn-primary">Explore Collection</a>
      <a href="/pages/about" class="btn btn-secondary">Learn More</a>
    </div>

    {% if section.settings.products != blank %}
      <div class="hero-visual">
        <div class="hero-grid">
          {% for product in section.settings.products %}
            <a href="{{ product.url }}" class="hero-card">
              <div class="hero-card-image-wrapper">
                <img src="{{ product.featured_image.src | img_url: '500x667' }}" alt="{{ product.title }}" class="hero-card-image">
              </div>
              <div class="hero-card-info">
                <span class="hero-card-title">{{ product.title }}</span>
                <span class="hero-card-price">{{ product.price | money }}</span>
              </div>
            </a>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</section>
{% schema %}
  {
    "name": "Hero Section",
    "settings": [
      {
        "type": "text",
        "id": "subtitle",
        "label": "Subtitle",
        "default": "Discover art prints from your favorite anime series"
      },
      {
        "type": "product_list",
        "id": "products",
        "label": "Products",
        "info": "Select products to display in hero grid"
      }
    ]
  }
{% endschema %}