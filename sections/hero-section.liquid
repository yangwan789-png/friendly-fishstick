<section class="hero-section">
  <div class="hero-content">
    <p class="hero-content__pre-title">Premium Anime Art Prints</p>
    <h1 class="hero-content__title">
      Discover Your Favorite <span class="hero-content__title-gradient">Anime Art</span>
    </h1>
    <p class="hero-content__subtitle">High-quality canvas prints featuring iconic characters from your favorite anime series.</p>
    <div class="hero-content__buttons">
      <a href="/collections/all" class="btn btn-primary">
        Shop Now
        <span>→</span>
      </a>
      <a href="/collections" class="btn btn-secondary">
        Browse Collections
      </a>
    </div>
    <div class="hero-stats">
      <div class="hero-stat">
        <div class="hero-stat__value">1000+</div>
        <div class="hero-stat__label">Art Prints</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat__value">50+</div>
        <div class="hero-stat__label">Anime Series</div>
      </div>
      <div class="hero-stat">
        <div class="hero-stat__value">50K+</div>
        <div class="hero-stat__label">Happy Customers</div>
      </div>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Hero Section",
  "settings": []
}
{% endschema %}