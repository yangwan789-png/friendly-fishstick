<section class="hero">
  <style>
    .hero {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      overflow: hidden;
      padding: 80px 0 60px;
    }

    .hero-bg {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: var(--color-bg);
    }

    .hero-bg::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle at 20% 80%, rgba(255, 42, 109, 0.15) 0%, transparent 50%),
                  radial-gradient(circle at 80% 20%, rgba(5, 217, 232, 0.15) 0%, transparent 50%),
                  radial-gradient(circle at 50% 50%, rgba(168, 85, 247, 0.1) 0%, transparent 70%);
      animation: gradient-shift 20s ease infinite;
    }

    .hero-container {
      position: relative;
      z-index: 1;
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 24px;
      text-align: center;
    }

    .hero-badge {
      display: inline-block;
      padding: 8px 20px;
      background: rgba(255, 42, 109, 0.15);
      border: 1px solid rgba(255, 42, 109, 0.3);
      border-radius: var(--radius-full);
      font-size: 13px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 2px;
      color: var(--color-primary);
      margin-bottom: 24px;
      animation: pulse 3s ease-in-out infinite;
    }

    .hero-title {
      font-size: clamp(3rem, 8vw, 5.5rem);
      font-weight: 900;
      line-height: 1.1;
      margin-bottom: 24px;
      position: relative;
    }

    .hero-title-gradient {
      background: linear-gradient(135deg, var(--color-primary), var(--color-secondary), var(--color-accent));
      background-size: 200% 200%;
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: gradient-shift 8s ease infinite;
    }

    .hero-subtitle {
      font-size: clamp(1.125rem, 3vw, 1.5rem);
      color: var(--color-text-subdued);
      max-width: 600px;
      margin: 0 auto 40px;
      line-height: 1.8;
    }

    .hero-stats {
      display: flex;
      justify-content: center;
      gap: 64px;
      margin-bottom: 48px;
      flex-wrap: wrap;
    }

    .stat-item {
      text-align: center;
    }

    .stat-number {
      font-size: clamp(2rem, 5vw, 3.5rem);
      font-weight: 900;
      background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      display: block;
    }

    .stat-label {
      font-size: 14px;
      color: var(--color-text-subdued);
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-top: 8px;
    }

    .hero-buttons {
      display: flex;
      justify-content: center;
      gap: 16px;
      flex-wrap: wrap;
    }

    .hero-visual {
      margin-top: 60px;
      position: relative;
    }

    .hero-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      max-width: 800px;
      margin: 0 auto;
    }

    .hero-card {
      aspect-ratio: 3/4;
      border-radius: var(--radius-xl);
      overflow: hidden;
      position: relative;
      transition: all 0.3s ease;
      cursor: pointer;
    }

    .hero-card:hover {
      transform: translateY(-8px) scale(1.05);
      z-index: 10;
      box-shadow: var(--shadow-lg), var(--shadow-glow);
    }

    .hero-card-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s ease;
    }

    .hero-card:hover .hero-card-image {
      transform: scale(1.1);
    }

    .hero-card-overlay {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(to top, rgba(0, 0, 0, 0.8), transparent);
      display: flex;
      align-items: flex-end;
      padding: 16px;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .hero-card:hover .hero-card-overlay {
      opacity: 1;
    }

    .hero-card-title {
      font-size: 14px;
      font-weight: 600;
      color: white;
    }

    .hero-card:nth-child(1) { grid-row: span 2; animation: float 6s ease-in-out infinite; }
    .hero-card:nth-child(2) { grid-row: span 1; animation: float 6s ease-in-out infinite 1s; }
    .hero-card:nth-child(3) { grid-row: span 1; animation: float 6s ease-in-out infinite 2s; }
    .hero-card:nth-child(4) { grid-row: span 2; animation: float 6s ease-in-out infinite 3s; }
    .hero-card:nth-child(5) { grid-row: span 1; animation: float 6s ease-in-out infinite 4s; }
    .hero-card:nth-child(6) { grid-row: span 1; animation: float 6s ease-in-out infinite 5s; }
    .hero-card:nth-child(7) { grid-row: span 1; animation: float 6s ease-in-out infinite 0.5s; }
    .hero-card:nth-child(8) { grid-row: span 1; animation: float 6s ease-in-out infinite 1.5s; }

    @media (max-width: 768px) {
      .hero {
        min-height: auto;
        padding: 100px 0 40px;
      }

      .hero-title {
        font-size: clamp(2rem, 10vw, 3.5rem);
      }

      .hero-stats {
        gap: 32px;
      }

      .stat-number {
        font-size: clamp(1.5rem, 8vw, 2.5rem);
      }

      .hero-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 8px;
      }

      .hero-card:nth-child(1),
      .hero-card:nth-child(4) {
        grid-row: span 1;
      }
    }
  </style>

  <div class="hero-bg"></div>
  <div class="hero-container">
    {% if section.settings.badge_text != blank %}
      <span class="hero-badge">{{ section.settings.badge_text }}</span>
    {% endif %}
    
    <h1 class="hero-title">
      <span class="hero-title-gradient">{{ section.settings.title_line_1 }}</span>
      {% if section.settings.title_line_2 != blank %}
        <br>
        <span class="hero-title-gradient">{{ section.settings.title_line_2 }}</span>
      {% endif %}
    </h1>
    
    {% if section.settings.subtitle != blank %}
      <p class="hero-subtitle">{{ section.settings.subtitle }}</p>
    {% endif %}

    <div class="hero-stats">
      <div class="stat-item">
        <span class="stat-number">{{ section.settings.stat_1_value }}</span>
        <span class="stat-label">{{ section.settings.stat_1_label }}</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">{{ section.settings.stat_2_value }}</span>
        <span class="stat-label">{{ section.settings.stat_2_label }}</span>
      </div>
      <div class="stat-item">
        <span class="stat-number">{{ section.settings.stat_3_value }}</span>
        <span class="stat-label">{{ section.settings.stat_3_label }}</span>
      </div>
    </div>

    <div class="hero-buttons">
      {% if section.settings.primary_button_text != blank %}
        <a href="{{ section.settings.primary_button_link }}" class="btn btn-primary">{{ section.settings.primary_button_text }}</a>
      {% endif %}
      {% if section.settings.secondary_button_text != blank %}
        <a href="{{ section.settings.secondary_button_link }}" class="btn btn-secondary">{{ section.settings.secondary_button_text }}</a>
      {% endif %}
    </div>

    {% if section.settings.products != blank %}
      <div class="hero-visual">
        <div class="hero-grid">
          {% for product in section.settings.products %}
            <a href="{{ product.url }}" class="hero-card">
              <img src="{{ product.featured_image.src | img_url: '500x667' }}" alt="{{ product.title }}" class="hero-card-image">
              <div class="hero-card-overlay">
                <span class="hero-card-title">{{ product.title }}</span>
              </div>
            </a>
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</section>
{% schema %}
{
  "name": "Hero Section",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "New Collection 2026"
    },
    {
      "type": "text",
      "id": "title_line_1",
      "label": "Title Line 1",
      "default": "Anime Art"
    },
    {
      "type": "text",
      "id": "title_line_2",
      "label": "Title Line 2",
      "default": "Prints"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "Discover premium art prints featuring your favorite anime characters. High-quality designs for true anime fans."
    },
    {
      "type": "text",
      "id": "stat_1_value",
      "label": "Stat 1 Value",
      "default": "1000+"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 Label",
      "default": "Art Prints"
    },
    {
      "type": "text",
      "id": "stat_2_value",
      "label": "Stat 2 Value",
      "default": "50+"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 Label",
      "default": "Anime Series"
    },
    {
      "type": "text",
      "id": "stat_3_value",
      "label": "Stat 3 Value",
      "default": "50K+"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 Label",
      "default": "Happy Customers"
    },
    {
      "type": "text",
      "id": "primary_button_text",
      "label": "Primary Button Text",
      "default": "Explore Collection"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary Button Link",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link",
      "default": "/pages/about"
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Products",
      "info": "Select products to display in hero grid"
    }
  ]
}
{% endschema %}