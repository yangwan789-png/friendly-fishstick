<section class="collection-banner">
  <style>
    .collection-banner {
      padding: 60px 0;
      background: var(--color-bg-secondary);
      border-bottom: 1px solid var(--color-border);
    }

    .collection-banner .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 24px;
      text-align: center;
    }

    .collection-banner h1 {
      font-size: clamp(2.5rem, 6vw, 4rem);
      margin-bottom: 16px;
      background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .collection-banner p {
      font-size: 1.125rem;
      color: var(--color-text-subdued);
      max-width: 700px;
      margin: 0 auto 12px;
      line-height: 1.8;
    }

    .collection-banner__count {
      font-size: 1rem !important;
      color: var(--color-secondary) !important;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-top: 16px !important;
    }

    @media (max-width: 768px) {
      .collection-banner {
        padding: 40px 0;
      }

      .collection-banner h1 {
        font-size: clamp(1.75rem, 5vw, 2.5rem);
      }

      .collection-banner p {
        font-size: 1rem;
      }
    }
  </style>

  <div class="container">
    {% case collection.handle %}
      {% when 'naruto' %}
        <h1>Naruto</h1>
        <p>Discover stunning art prints featuring your favorite Naruto characters. From the Hidden Leaf Village to epic battles, find the perfect piece for your collection.</p>
        <p class="collection-banner__count">5 Characters Available</p>
      
      {% when 'one-piece' %}
        <h1>One Piece</h1>
        <p>Set sail with the Straw Hat Pirates! Explore our One Piece art print collection featuring Luffy and his crew on their adventure to find the legendary treasure.</p>
        <p class="collection-banner__count">5 Characters Available</p>
      
      {% when 'dragon-ball' %}
        <h1>Dragon Ball</h1>
        <p>Power up your space with Dragon Ball art prints! From Goku's epic transformations to legendary battles, bring the action to your walls.</p>
        <p class="collection-banner__count">5 Characters Available</p>
      
      {% when 'marvel' %}
        <h1>Marvel</h1>
        <p>Assemble your dream collection with Marvel art prints! Featuring iconic superheroes from the Avengers and beyond.</p>
        <p class="collection-banner__count">5 Characters Available</p>
      
      {% else %}
        <h1>{{ collection.title }}</h1>
        {% if collection.description %}
          <p>{{ collection.description }}</p>
        {% endif %}
        {% if collection.products_count > 0 %}
          <p class="collection-banner__count">{{ collection.products_count }} art prints available</p>
        {% endif %}
    {% endcase %}
  </div>
</section>
{% schema %}
{
  "name": "Collection Banner",
  "settings": []
}
{% endschema %}