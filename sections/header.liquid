<header class="header">
  <div class="header__content">
    <a href="{{ routes.root_url }}" class="header__logo">
      <div class="header__logo-icon">MK</div>
      <span class="header__logo-text">MangaKing</span>
    </a>
    <nav class="header__navigation">
      <div class="header__nav-dropdown">
        <a href="/collections" class="header__nav-link header__nav-link--dropdown">
          Series
          <span class="header__nav-arrow">▼</span>
        </a>
        <div class="header__dropdown-menu">
          <a href="/collections/naruto" class="header__dropdown-link">
            <span class="header__dropdown-icon">🍥</span>
            Naruto
          </a>
          <a href="/collections/one-piece" class="header__dropdown-link">
            <span class="header__dropdown-icon">🏴‍☠️</span>
            One Piece
          </a>
          <a href="/collections/dragon-ball" class="header__dropdown-link">
            <span class="header__dropdown-icon">🐉</span>
            Dragon Ball
          </a>
          <a href="/collections/marvel" class="header__dropdown-link">
            <span class="header__dropdown-icon">🦸</span>
            Marvel
          </a>
        </div>
      </div>
      <a href="/collections/all" class="header__nav-link">All Products</a>
      <a href="/pages/about" class="header__nav-link">About</a>
    </nav>
    <div class="header__actions">
      <a href="{{ routes.search_url }}" class="header__action-link">
        <span>🔍</span>
      </a>
      <a href="{{ routes.account_url }}" class="header__action-link">
        <span>👤</span>
      </a>
      <a href="{{ routes.cart_url }}" class="header__action-link">
        <span>🛒</span>
        {% if cart.item_count > 0 %}
          <span class="header__cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
      <button class="header__mobile-toggle">
        <span>☰</span>
      </button>
    </div>
  </div>
</header>
{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "Dark"
    }
  ]
}
{% endschema %}