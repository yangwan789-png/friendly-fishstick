<header class="header">
  <div class="header__content">
    <a href="{{ routes.root_url }}" class="header__logo">
      <div class="header__logo-icon">MK</div>
      <span class="header__logo-text">{{ shop.name }}</span>
    </a>
    <nav class="header__navigation">
      <a href="/collections/all" class="header__nav-link">All Products</a>
      <a href="/collections" class="header__nav-link">Collections</a>
      <a href="/pages/about" class="header__nav-link">About</a>
    </nav>
    <div class="header__actions">
      <a href="{{ routes.search_url }}" class="header__action-link">
        <span>🔍</span>
      </a>
      <a href="{{ routes.account_url }}" class="header__action-link">
        <span>👤</span>
      </a>
      <a href="{{ routes.cart_url }}" class="header__action-link">
        <span>🛒</span>
        {% if cart.item_count > 0 %}
          <span class="header__cart-count">{{ cart.item_count }}</span>
        {% endif %}
      </a>
      <button class="header__mobile-toggle">
        <span>☰</span>
      </button>
    </div>
  </div>
</header>
{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "Dark"
    },
    {
      "type": "select",
      "id": "logo_position",
      "label": "Logo position",
      "default": "middle-center",
      "options": [
        {"value": "left", "label": "Left"},
        {"value": "middle-center", "label": "Center"},
        {"value": "right", "label": "Right"}
      ]
    }
  ]
}
{% endschema %}