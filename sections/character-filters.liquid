<section class="character-filters">
  <div class="container">
    <h3 class="character-filters__title">Characters</h3>
    <div class="character-filters__list">
      <button class="character-filter__item {% unless current_tags %}active{% endunless %}" data-tag="">
        <span class="character-filter__name">All Characters</span>
        <span class="character-filter__count">{{ collection.products_count }}</span>
      </button>
      {% assign character_tags = collection.all_tags | where_exp: 'tag', 'tag contains 'Character'' %}
      {% for tag in character_tags %}
        {% assign tag_name = tag | replace: 'Character_', '' %}
        {% assign tag_count = collection.products | where: 'tags', tag | size %}
        <button class="character-filter__item {% if current_tags contains tag %}active{% endif %}" data-tag="{{ tag }}">
          <span class="character-filter__name">{{ tag_name }}</span>
          <span class="character-filter__count">{{ tag_count }}</span>
        </button>
      {% endfor %}
    </div>
  </div>
</section>
<script>
  document.addEventListener('DOMContentLoaded', function() {
    const filterButtons = document.querySelectorAll('.character-filter__item');
    const collectionUrl = '{{ collection.url }}';
    
    filterButtons.forEach(button => {
      button.addEventListener('click', function() {
        const tag = this.dataset.tag;
        let url = collectionUrl;
        if (tag) {
          url = `${collectionUrl}/${tag}`;
        }
        window.location.href = url;
      });
    });
  });
</script>
{% schema %}
{
  "name": "Character Filters",
  "settings": []
}
{% endschema %}