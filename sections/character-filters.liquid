<section class="character-filters">
  <style>
    .character-filters {
      padding: 32px 0;
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
    }

    .character-filters .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .character-filters__title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--color-text-subdued);
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 16px;
    }

    .character-filters__list {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .character-filter__item {
      padding: 10px 20px;
      background: var(--color-bg-card);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-full);
      font-size: 13px;
      font-weight: 500;
      color: var(--color-text);
      cursor: pointer;
      transition: all 0.3s ease;
      white-space: nowrap;
    }

    .character-filter__item:hover {
      border-color: var(--color-primary);
      color: var(--color-primary);
    }

    .character-filter__item.active {
      background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
      border-color: transparent;
      color: white;
      box-shadow: var(--shadow-glow);
    }

    @media (max-width: 768px) {
      .character-filters {
        padding: 24px 0;
      }

      .character-filters .container {
        padding: 0 16px;
      }

      .character-filter__item {
        padding: 8px 16px;
        font-size: 12px;
      }
    }
  </style>

  <div class="container">
    <h3 class="character-filters__title">Characters</h3>
    <div class="character-filters__list">
      <button class="character-filter__item active" data-character="">
        <span class="character-filter__name">All Characters</span>
      </button>
      
      {% if collection.handle == 'naruto' %}
        <button class="character-filter__item" data-character="naruto-uzumaki">
          <span class="character-filter__name">Naruto Uzumaki</span>
        </button>
        <button class="character-filter__item" data-character="sasuke-uchiha">
          <span class="character-filter__name">Sasuke Uchiha</span>
        </button>
        <button class="character-filter__item" data-character="sakura-haruno">
          <span class="character-filter__name">Sakura Haruno</span>
        </button>
        <button class="character-filter__item" data-character="kakashi-hatake">
          <span class="character-filter__name">Kakashi Hatake</span>
        </button>
        <button class="character-filter__item" data-character="itachi-uchiha">
          <span class="character-filter__name">Itachi Uchiha</span>
        </button>
      {% endif %}
      
      {% if collection.handle == 'one-piece' %}
        <button class="character-filter__item" data-character="monkey-d-luffy">
          <span class="character-filter__name">Monkey D. Luffy</span>
        </button>
        <button class="character-filter__item" data-character="roronoa-zoro">
          <span class="character-filter__name">Roronoa Zoro</span>
        </button>
        <button class="character-filter__item" data-character="nami">
          <span class="character-filter__name">Nami</span>
        </button>
        <button class="character-filter__item" data-character="sanji">
          <span class="character-filter__name">Sanji</span>
        </button>
        <button class="character-filter__item" data-character="tony-tony-chopper">
          <span class="character-filter__name">Tony Tony Chopper</span>
        </button>
      {% endif %}
      
      {% if collection.handle == 'dragon-ball' %}
        <button class="character-filter__item" data-character="goku">
          <span class="character-filter__name">Goku</span>
        </button>
        <button class="character-filter__item" data-character="vegeta">
          <span class="character-filter__name">Vegeta</span>
        </button>
        <button class="character-filter__item" data-character="piccolo">
          <span class="character-filter__name">Piccolo</span>
        </button>
        <button class="character-filter__item" data-character="gohan">
          <span class="character-filter__name">Gohan</span>
        </button>
        <button class="character-filter__item" data-character="frieza">
          <span class="character-filter__name">Frieza</span>
        </button>
      {% endif %}
      
      {% if collection.handle == 'marvel' %}
        <button class="character-filter__item" data-character="spider-man">
          <span class="character-filter__name">Spider-Man</span>
        </button>
        <button class="character-filter__item" data-character="iron-man">
          <span class="character-filter__name">Iron Man</span>
        </button>
        <button class="character-filter__item" data-character="captain-america">
          <span class="character-filter__name">Captain America</span>
        </button>
        <button class="character-filter__item" data-character="thor">
          <span class="character-filter__name">Thor</span>
        </button>
        <button class="character-filter__item" data-character="black-widow">
          <span class="character-filter__name">Black Widow</span>
        </button>
      {% endif %}
    </div>
  </div>

  <script>
    document.addEventListener('DOMContentLoaded', function() {
      const filterButtons = document.querySelectorAll('.character-filter__item');
      
      filterButtons.forEach(button => {
        button.addEventListener('click', function() {
          filterButtons.forEach(btn => btn.classList.remove('active'));
          this.classList.add('active');
          
          const character = this.dataset.character;
          const products = document.querySelectorAll('.product-card');
          
          products.forEach(product => {
            if (!character || product.dataset.character === character) {
              product.style.display = '';
            } else {
              product.style.display = 'none';
            }
          });
        });
      });
    });
  </script>
</section>
{% schema %}
{
  "name": "Character Filters",
  "settings": []
}
{% endschema %}