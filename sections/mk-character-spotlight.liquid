{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- assign source_collection = collections[section.settings.source_collection] -%}
{%- if source_collection == blank -%}
  {%- assign source_collection = collections['all'] -%}
{%- endif -%}

{%- liquid
  assign prefix = section.settings.tag_prefix
  assign tags = '' | split: ','
  for t in source_collection.all_tags
    if t | slice: 0, prefix.size == prefix
      assign tags = tags | push: t
    endif
  endfor
-%}

<div class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}" data-mk-character-spotlight>
  <div class="page-width">
    <div class="mk-section-title">
      <h2 class="mk-section-title__heading {{ section.settings.heading_size }}">{{ section.settings.heading | escape }}</h2>
      {%- if section.settings.cta_label != blank -%}
        <a class="mk-chip" href="{{ section.settings.cta_link | default: routes.root_url }}">{{ section.settings.cta_label | escape }}</a>
      {%- endif -%}
    </div>

    <div class="mk-character-grid" data-mk-list></div>

    <script type="application/json" data-mk-data>
      {
        "tags": {{ tags | json }},
        "limit": {{ section.settings.limit | json }},
        "baseUrl": {{ section.settings.base_collection_url | json }},
        "prefix": {{ prefix | json }}
      }
    </script>

    <noscript>
      <div class="mk-character-grid">
        {%- for t in tags limit: section.settings.limit -%}
          {%- assign slug = t | remove: prefix -%}
          <a class="mk-character-card" href="{{ section.settings.base_collection_url }}/{{ t | handleize }}">
            <span class="mk-character-card__label">{{ slug | replace: '-', ' ' | capitalize }}</span>
          </a>
        {%- endfor -%}
      </div>
    </noscript>
  </div>
</div>

{% schema %}
{
  "name": "MK character spotlight",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Character spotlight"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading size",
      "default": "h1",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ]
    },
    {
      "type": "collection",
      "id": "source_collection",
      "label": "Tag source collection",
      "info": "Default is all products."
    },
    {
      "type": "text",
      "id": "tag_prefix",
      "label": "Character tag prefix",
      "default": "character:"
    },
    {
      "type": "number",
      "id": "limit",
      "label": "Count",
      "default": 6
    },
    {
      "type": "text",
      "id": "base_collection_url",
      "label": "Result base URL",
      "default": "/collections/all"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "All characters"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "MK character spotlight"
    }
  ]
}
{% endschema %}
