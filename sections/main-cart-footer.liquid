<section class="cart-footer">
  <div class="container">
    <div class="cart-footer__subtotal">
      <span class="cart-footer__label">Subtotal</span>
      <span class="cart-footer__value">{{ cart.total_price | money }}</span>
    </div>
    {% if cart.total_weight > 0 %}
      <div class="cart-footer__shipping">
        <span class="cart-footer__label">Shipping</span>
        <span class="cart-footer__value">Calculated at checkout</span>
      </div>
    {% endif %}
    <div class="cart-footer__buttons">
      <a href="/checkout" class="btn btn-primary">Proceed to Checkout</a>
      <a href="/collections/all" class="btn btn-secondary">Continue Shopping</a>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Main Cart Footer",
  "settings": []
}
{% endschema %}