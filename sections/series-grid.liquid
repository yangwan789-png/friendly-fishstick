<section class="series-section">
  <style>
    .series-section {
      padding: 80px 0;
      background: var(--color-bg-secondary);
      position: relative;
    }

    .series-section::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--color-border), transparent);
    }

    .series-container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .section-header {
      text-align: center;
      margin-bottom: 56px;
    }

    .section-title {
      font-size: clamp(2rem, 5vw, 3.5rem);
      margin-bottom: 16px;
    }

    .section-title span {
      background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .section-subtitle {
      font-size: 1.125rem;
      color: var(--color-text-subdued);
      max-width: 600px;
      margin: 0 auto;
    }

    .series-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
    }

    .series-card {
      position: relative;
      border-radius: var(--radius-xl);
      overflow: hidden;
      cursor: pointer;
      transition: all 0.4s ease;
      border: 1px solid var(--color-border);
      background: var(--color-bg-card);
    }

    .series-card:hover {
      transform: translateY(-12px);
      border-color: var(--color-primary);
      box-shadow: var(--shadow-lg), var(--shadow-glow);
    }

    .series-card-image {
      width: 100%;
      height: auto;
      object-fit: contain;
      transition: transform 0.5s ease;
      display: block;
    }

    .series-card:hover .series-card-image {
      transform: scale(1.1);
    }

    .series-card-overlay {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(to top, rgba(0, 0, 0, 0.9), rgba(0, 0, 0, 0.3), transparent);
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 24px;
      transition: all 0.3s ease;
    }

    .series-card:hover .series-card-overlay {
      background: linear-gradient(to top, rgba(0, 0, 0, 0.95), rgba(255, 42, 109, 0.2), transparent);
    }

    .series-card-badge {
      display: inline-block;
      padding: 4px 12px;
      background: rgba(255, 42, 109, 0.9);
      border-radius: var(--radius-full);
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 12px;
      width: fit-content;
    }

    .series-card-title {
      font-size: 1.75rem;
      font-weight: 800;
      margin-bottom: 8px;
      position: relative;
      z-index: 1;
    }

    .series-card-count {
      font-size: 14px;
      color: var(--color-text-subdued);
      margin-bottom: 16px;
    }

    .series-card-button {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 20px;
      background: rgba(255, 42, 109, 0.9);
      border-radius: var(--radius-full);
      font-size: 13px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      opacity: 0;
      transform: translateY(10px);
      transition: all 0.3s ease;
    }

    .series-card:hover .series-card-button {
      opacity: 1;
      transform: translateY(0);
    }

    .series-card-button:hover {
      background: var(--color-primary);
      box-shadow: var(--shadow-glow);
    }

    .series-card-button svg {
      transition: transform 0.3s ease;
    }

    .series-card-button:hover svg {
      transform: translateX(4px);
    }

    @media (max-width: 768px) {
      .series-section {
        padding: 60px 0;
      }

      .series-grid {
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 16px;
      }

      .series-card {
        aspect-ratio: 3/4;
      }

      .series-card-title {
        font-size: 1.25rem;
      }
    }
  </style>

  <div class="series-container">
    <div class="section-header">
      <h2 class="section-title">Explore Popular <span>Series</span></h2>
      <p class="section-subtitle">{{ section.settings.subtitle }}</p>
    </div>

    <div class="series-grid">
      {% if section.settings.collections != blank %}
        {% for collection in section.settings.collections %}
          <a href="{{ collection.url }}" class="series-card">
            <img src="{{ collection.image | img_url: '600x750' }}" alt="{{ collection.title }}" class="series-card-image">
            <div class="series-card-overlay">
              <span class="series-card-badge">{{ collection.products_count }}+ Prints</span>
              <h3 class="series-card-title">{{ collection.title }}</h3>
              <p class="series-card-count">{{ collection.description | strip_html | truncate: 60 }}</p>
              <span class="series-card-button">
                View Collection
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7"></path>
                </svg>
              </span>
            </div>
          </a>
        {% endfor %}
      {% else %}
        <a href="/collections/naruto" class="series-card">
          <img src="https://neeko-copilot.bytedance.net/api/text_to_image?prompt=naruto%20anime%20series%20hero%20shot%20dramatic%20dark%20background%20orange%20theme&image_size=portrait_4_3" alt="Naruto" class="series-card-image">
          <div class="series-card-overlay">
            <span class="series-card-badge">50+ Prints</span>
            <h3 class="series-card-title">Naruto</h3>
            <p class="series-card-count">Characters: Naruto, Sasuke, Sakura, Kakashi, Itachi</p>
            <span class="series-card-button">
              View Collection
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"></path>
              </svg>
            </span>
          </div>
        </a>

        <a href="/collections/one-piece" class="series-card">
          <img src="https://neeko-copilot.bytedance.net/api/text_to_image?prompt=one%20piece%20anime%20series%20luffy%20dramatic%20dark%20background%20red%20theme&image_size=portrait_4_3" alt="One Piece" class="series-card-image">
          <div class="series-card-overlay">
            <span class="series-card-badge">60+ Prints</span>
            <h3 class="series-card-title">One Piece</h3>
            <p class="series-card-count">Characters: Luffy, Zoro, Nami, Sanji, Chopper</p>
            <span class="series-card-button">
              View Collection
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"></path>
              </svg>
            </span>
          </div>
        </a>

        <a href="/collections/dragon-ball" class="series-card">
          <img src="https://neeko-copilot.bytedance.net/api/text_to_image?prompt=dragon%20ball%20goku%20super%20saiyan%20dramatic%20dark%20background%20yellow%20aura&image_size=portrait_4_3" alt="Dragon Ball" class="series-card-image">
          <div class="series-card-overlay">
            <span class="series-card-badge">45+ Prints</span>
            <h3 class="series-card-title">Dragon Ball</h3>
            <p class="series-card-count">Characters: Goku, Vegeta, Piccolo, Gohan, Frieza</p>
            <span class="series-card-button">
              View Collection
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"></path>
              </svg>
            </span>
          </div>
        </a>

        <a href="/collections/marvel" class="series-card">
          <img src="https://neeko-copilot.bytedance.net/api/text_to_image?prompt=marvel%20superheroes%20team%20dramatic%20dark%20background%20epic%20pose&image_size=portrait_4_3" alt="Marvel" class="series-card-image">
          <div class="series-card-overlay">
            <span class="series-card-badge">70+ Prints</span>
            <h3 class="series-card-title">Marvel</h3>
            <p class="series-card-count">Characters: Spider-Man, Iron Man, Captain America, Thor, Black Widow</p>
            <span class="series-card-button">
              View Collection
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M5 12h14M12 5l7 7-7 7"></path>
              </svg>
            </span>
          </div>
        </a>
      {% endif %}
    </div>
  </div>

  {% schema %}
    {
      "name": "Series Grid",
      "settings": [
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Discover art prints from your favorite anime series"
        },
        {
          "type": "collection_list",
          "id": "collections",
          "label": "Collections",
          "info": "Select collections to display as series cards"
        }
      ]
    }
  {% endschema %}
</section>