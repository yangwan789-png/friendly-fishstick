<section class="cart-section">
  <div class="container">
    {% if cart.items.size > 0 %}
      <div class="cart-items">
        {% for item in cart.items %}
          <div class="cart-item">
            <div class="cart-item__image">
              <img src="{{ item.image | img_url: 'medium' }}" alt="{{ item.product.title }}">
            </div>
            <div class="cart-item__info">
              <h3 class="cart-item__title">{{ item.product.title }}</h3>
              {% if item.variant.title != 'Default Title' %}
                <p class="cart-item__variant">{{ item.variant.title }}</p>
              {% endif %}
              <div class="cart-item__price">{{ item.price | money }}</div>
            </div>
            <div class="cart-item__quantity">
              <button class="cart-item__quantity-btn" onclick="updateQuantity({{ item.key }}, -1)">-</button>
              <span class="cart-item__quantity-value">{{ item.quantity }}</span>
              <button class="cart-item__quantity-btn" onclick="updateQuantity({{ item.key }}, 1)">+</button>
            </div>
            <div class="cart-item__total">{{ item.line_price | money }}</div>
            <button class="cart-item__remove" onclick="removeItem({{ item.key }})">×</button>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="cart-empty">
        <p>Your cart is empty</p>
        <a href="/collections/all" class="btn btn-primary">Start Shopping</a>
      </div>
    {% endif %}
  </div>
</section>
{% schema %}
{
  "name": "Main Cart Items",
  "settings": []
}
{% endschema %}