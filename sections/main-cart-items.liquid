<section class="cart-section">
  <style>
    .cart-section {
      padding: 120px 24px 60px;
      max-width: 1200px;
      margin: 0 auto;
    }

    .cart-header {
      text-align: center;
      margin-bottom: 48px;
    }

    .cart-title {
      font-size: 2.5rem;
      font-weight: 800;
      margin-bottom: 16px;
      background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .cart-subtitle {
      font-size: 1.125rem;
      color: var(--color-text-subdued);
    }

    .cart-content {
      display: grid;
      grid-template-columns: 1fr 380px;
      gap: 32px;
    }

    .cart-items {
      background: var(--color-bg-card);
      border-radius: var(--radius-xl);
      padding: 32px;
      border: 1px solid var(--color-border);
    }

    .cart-empty {
      text-align: center;
      padding: 80px 24px;
    }

    .cart-empty-icon {
      font-size: 4rem;
      margin-bottom: 24px;
      opacity: 0.5;
    }

    .cart-empty-title {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 16px;
    }

    .cart-empty-text {
      font-size: 1rem;
      color: var(--color-text-subdued);
      margin-bottom: 24px;
    }

    .cart-empty-btn {
      padding: 14px 32px;
      border-radius: var(--radius-full);
      background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
      font-size: 14px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      transition: all 0.3s ease;
    }

    .cart-empty-btn:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-glow);
    }

    .cart-item {
      display: flex;
      gap: 20px;
      padding: 24px 0;
      border-bottom: 1px solid var(--color-border);
    }

    .cart-item:last-child {
      border-bottom: none;
    }

    .cart-item-image-wrapper {
      width: 120px;
      height: 120px;
      border-radius: var(--radius-lg);
      overflow: hidden;
      flex-shrink: 0;
      background: var(--color-bg);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .cart-item-image {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .cart-item-details {
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    .cart-item-title {
      font-size: 1.125rem;
      font-weight: 700;
      margin-bottom: 8px;
      color: var(--color-text);
    }

    .cart-item-variant {
      font-size: 0.875rem;
      color: var(--color-text-subdued);
      margin-bottom: 12px;
    }

    .cart-item-price {
      font-size: 1.25rem;
      font-weight: 700;
      color: var(--color-primary);
      margin-top: auto;
    }

    .cart-item-quantity {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-top: 16px;
    }

    .quantity-btn {
      width: 36px;
      height: 36px;
      border-radius: var(--radius-full);
      background: var(--color-bg);
      border: 1px solid var(--color-border);
      font-size: 1rem;
      font-weight: 600;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .quantity-btn:hover {
      border-color: var(--color-primary);
      color: var(--color-primary);
    }

    .quantity-input {
      width: 60px;
      height: 36px;
      border-radius: var(--radius-md);
      background: var(--color-bg);
      border: 1px solid var(--color-border);
      text-align: center;
      font-size: 1rem;
      font-weight: 600;
      color: var(--color-text);
      outline: none;
    }

    .quantity-input:focus {
      border-color: var(--color-primary);
    }

    .cart-item-remove {
      margin-top: 12px;
      font-size: 0.875rem;
      color: var(--color-text-subdued);
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .cart-item-remove:hover {
      color: var(--color-primary);
    }

    .cart-sidebar {
      background: var(--color-bg-card);
      border-radius: var(--radius-xl);
      padding: 32px;
      border: 1px solid var(--color-border);
      position: sticky;
      top: 120px;
    }

    .cart-sidebar-title {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 24px;
    }

    .cart-summary {
      display: flex;
      justify-content: space-between;
      margin-bottom: 12px;
      font-size: 1rem;
    }

    .cart-summary-label {
      color: var(--color-text-subdued);
    }

    .cart-summary-value {
      font-weight: 600;
    }

    .cart-summary-total {
      display: flex;
      justify-content: space-between;
      margin-top: 24px;
      padding-top: 24px;
      border-top: 1px solid var(--color-border);
      font-size: 1.5rem;
      font-weight: 700;
    }

    .cart-summary-total-value {
      color: var(--color-primary);
    }

    .cart-checkout-btn {
      width: 100%;
      padding: 18px;
      border-radius: var(--radius-lg);
      background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
      font-size: 1.125rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-top: 24px;
      color: white;
      cursor: pointer;
      transition: all 0.3s ease;
    }

    .cart-checkout-btn:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-glow);
    }

    .shipping-modal {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.8);
      display: flex;
      align-items: center;
      justify-content: center;
      z-index: 9999;
      opacity: 0;
      visibility: hidden;
      transition: all 0.3s ease;
    }

    .shipping-modal.active {
      opacity: 1;
      visibility: visible;
    }

    .shipping-modal-content {
      background: var(--color-bg-card);
      border-radius: var(--radius-xl);
      padding: 40px;
      max-width: 420px;
      width: 90%;
      text-align: center;
      transform: scale(0.9);
      transition: transform 0.3s ease;
    }

    .shipping-modal.active .shipping-modal-content {
      transform: scale(1);
    }

    .shipping-modal-icon {
      font-size: 3.5rem;
      margin-bottom: 20px;
      color: var(--color-secondary);
    }

    .shipping-modal-title {
      font-size: 1.5rem;
      font-weight: 700;
      margin-bottom: 12px;
    }

    .shipping-modal-text {
      font-size: 1rem;
      color: var(--color-text-subdued);
      margin-bottom: 24px;
    }

    .shipping-modal-highlight {
      color: var(--color-primary);
      font-weight: 700;
    }

    .shipping-modal-buttons {
      display: flex;
      gap: 12px;
    }

    .shipping-modal-btn {
      flex: 1;
      padding: 14px;
      border-radius: var(--radius-lg);
      font-size: 14px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      cursor: pointer;
      transition: all 0.3s ease;
      border: none;
    }

    .shipping-modal-btn-primary {
      background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
      color: white;
    }

    .shipping-modal-btn-secondary {
      background: var(--color-bg);
      color: var(--color-text);
      border: 1px solid var(--color-border);
    }

    .shipping-modal-btn-primary:hover,
    .shipping-modal-btn-secondary:hover {
      transform: translateY(-2px);
    }

    .cart-policy {
      margin-top: 24px;
      padding: 16px;
      background: var(--color-bg);
      border-radius: var(--radius-lg);
    }

    .cart-policy-item {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 0.875rem;
      color: var(--color-text-subdued);
      margin-bottom: 8px;
    }

    .cart-policy-item:last-child {
      margin-bottom: 0;
    }

    .cart-policy-icon {
      color: var(--color-secondary);
    }

    @media (max-width: 992px) {
      .cart-content {
        grid-template-columns: 1fr;
      }

      .cart-sidebar {
        position: static;
      }
    }

    @media (max-width: 768px) {
      .cart-title {
        font-size: 1.75rem;
      }

      .cart-items,
      .cart-sidebar {
        padding: 24px;
      }

      .cart-item {
        flex-direction: column;
      }

      .cart-item-image-wrapper {
        width: 100%;
        height: 200px;
      }

      .cart-item-details {
        width: 100%;
      }
    }
  </style>

  <div class="shipping-modal" id="shippingModal">
    <div class="shipping-modal-content">
      <div class="shipping-modal-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 7h-9"></path>
          <path d="M14 17H5"></path>
          <path d="M19 17c0-2-3-5-7-5s-7 3-7 5a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2Z"></path>
          <circle cx="12" cy="7" r="4"></circle>
        </svg>
      </div>
      <h3 class="shipping-modal-title">Free Shipping Alert!</h3>
      <p class="shipping-modal-text">
        Order <span class="shipping-modal-highlight">2+ items</span> to enjoy <span class="shipping-modal-highlight">FREE shipping</span>!
      </p>
      <div class="shipping-modal-buttons">
        <button class="shipping-modal-btn shipping-modal-btn-secondary" id="continueAnyway">Continue</button>
        <button class="shipping-modal-btn shipping-modal-btn-primary" id="addMoreItems">Add More</button>
      </div>
    </div>
  </div>

  <div class="cart-header">
    <h1 class="cart-title">Your Cart</h1>
    <p class="cart-subtitle">{{ cart.item_count }} items</p>
  </div>

  <div class="cart-content">
    <div class="cart-items">
      {% if cart.items.size == 0 %}
        <div class="cart-empty">
          <div class="cart-empty-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"></path>
              <line x1="3" y1="6" x2="21" y2="6"></line>
              <path d="M16 10a4 4 0 0 1-8 0"></path>
            </svg>
          </div>
          <h2 class="cart-empty-title">Your cart is empty</h2>
          <p class="cart-empty-text">Start shopping and add some amazing anime art prints to your cart!</p>
          <a href="/collections/all" class="cart-empty-btn">Start Shopping</a>
        </div>
      {% else %}
        {% for item in cart.items %}
          <div class="cart-item">
            <div class="cart-item-image-wrapper">
              {% if item.featured_image %}
                <img src="{{ item.featured_image | img_url: '500x500' }}" alt="{{ item.title }}" class="cart-item-image">
              {% elsif item.image %}
                <img src="{{ item.image | img_url: '500x500' }}" alt="{{ item.title }}" class="cart-item-image">
              {% elsif item.variant.featured_image %}
                <img src="{{ item.variant.featured_image | img_url: '500x500' }}" alt="{{ item.title }}" class="cart-item-image">
              {% else %}
                <img src="{{ 'product-1.png' | asset_url }}" alt="{{ item.title }}" class="cart-item-image">
              {% endif %}
            </div>
            <div class="cart-item-details">
              <a href="{{ item.url }}" class="cart-item-title">{{ item.title }}</a>
              <span class="cart-item-variant">
                {% if item.variant.title != 'Default Title' %}
                  {{ item.variant.title }}
                {% endif %}
              </span>
              <span class="cart-item-price">{{ item.price | money }}</span>
              <div class="cart-item-quantity">
                <button class="quantity-btn" onclick="changeQuantity({{ item.id }}, {{ item.quantity | minus: 1 }})">-</button>
                <input type="number" class="quantity-input" value="{{ item.quantity }}" min="1" readonly>
                <button class="quantity-btn" onclick="changeQuantity({{ item.id }}, {{ item.quantity | plus: 1 }})">+</button>
              </div>
              <span class="cart-item-remove" onclick="removeItem({{ item.id }})">Remove</span>
            </div>
          </div>
        {% endfor %}
      {% endif %}
    </div>

    <div class="cart-sidebar">
      <h2 class="cart-sidebar-title">Order Summary</h2>
      
      <div class="cart-summary">
        <span class="cart-summary-label">Subtotal</span>
        <span class="cart-summary-value">{{ cart.subtotal_price | money }}</span>
      </div>
      
      {% if cart.shipping_price > 0 %}
        <div class="cart-summary">
          <span class="cart-summary-label">Shipping</span>
          <span class="cart-summary-value">{{ cart.shipping_price | money }}</span>
        </div>
      {% endif %}
      
      {% if cart.tax_price > 0 %}
        <div class="cart-summary">
          <span class="cart-summary-label">Tax</span>
          <span class="cart-summary-value">{{ cart.tax_price | money }}</span>
        </div>
      {% endif %}

      <div class="cart-summary-total">
        <span class="cart-summary-label">Total</span>
        <span class="cart-summary-total-value">{{ cart.total_price | money }}</span>
      </div>

      <button class="cart-checkout-btn" onclick="checkout()">Proceed to Checkout</button>

      <div class="cart-policy">
        <div class="cart-policy-item">
          <span class="cart-policy-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 7h-9"></path>
              <path d="M14 17H5"></path>
              <path d="M19 17c0-2-3-5-7-5s-7 3-7 5a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2Z"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
          </span>
          <span>Free shipping on orders with 2+ items</span>
        </div>
        <div class="cart-policy-item">
          <span class="cart-policy-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 12l2 2 4-4"></path>
              <circle cx="12" cy="12" r="10"></circle>
            </svg>
          </span>
          <span>30-day money-back guarantee</span>
        </div>
        <div class="cart-policy-item">
          <span class="cart-policy-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="1" y="3" width="15" height="13"></rect>
              <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
              <circle cx="5.5" cy="18.5" r="2.5"></circle>
              <circle cx="18.5" cy="18.5" r="2.5"></circle>
            </svg>
          </span>
          <span>Secure checkout</span>
        </div>
      </div>
    </div>
  </div>

  <script>
    function changeQuantity(lineItemId, newQuantity) {
      if (newQuantity < 1) {
        removeItem(lineItemId);
        return;
      }
      
      const formData = new FormData();
      formData.append('id', lineItemId);
      formData.append('quantity', newQuantity);
      
      fetch('/cart/change.js', {
        method: 'POST',
        body: formData
      })
      .then(response => response.json())
      .then(() => {
        window.location.reload();
      })
      .catch(error => {
        console.error('Error updating quantity:', error);
      });
    }

    function removeItem(lineItemId) {
      const formData = new FormData();
      formData.append('id', lineItemId);
      formData.append('quantity', 0);
      
      fetch('/cart/change.js', {
        method: 'POST',
        body: formData
      })
      .then(response => response.json())
      .then(() => {
        window.location.reload();
      })
      .catch(error => {
        console.error('Error removing item:', error);
      });
    }

    const checkoutBtn = document.querySelector('.cart-checkout-btn');
    const shippingModal = document.getElementById('shippingModal');
    const continueAnywayBtn = document.getElementById('continueAnyway');
    const addMoreItemsBtn = document.getElementById('addMoreItems');

    checkoutBtn.addEventListener('click', function(e) {
      e.preventDefault();
      
      fetch('/cart.js')
      .then(response => response.json())
      .then(cart => {
        const totalItems = cart.items.reduce((sum, item) => sum + item.quantity, 0);
        
        if (totalItems < 2) {
          shippingModal.classList.add('active');
          return;
        }
        
        window.location.href = '/checkout';
      })
      .catch(error => {
        console.error('Error fetching cart:', error);
        window.location.href = '/checkout';
      });
    });

    continueAnywayBtn.addEventListener('click', function() {
      shippingModal.classList.remove('active');
      window.location.href = '/checkout';
    });

    addMoreItemsBtn.addEventListener('click', function() {
      shippingModal.classList.remove('active');
      window.location.href = '/collections/all';
    });

    shippingModal.addEventListener('click', function(e) {
      if (e.target === shippingModal) {
        shippingModal.classList.remove('active');
      }
    });
  </script>
</section>