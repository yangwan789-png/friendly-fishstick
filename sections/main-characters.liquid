{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign character_prefix = section.settings.tag_prefix
  assign tags = '' | split: ','
  for t in collections['all'].all_tags
    if t | slice: 0, character_prefix.size == character_prefix
      assign tags = tags | push: t
    endif
  endfor
-%}

<div class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}" data-mk-character-search>
  <div class="page-width">
    <div class="mk-section-title">
      <h1 class="mk-section-title__heading">{{ page.title | default: section.settings.heading | escape }}</h1>
    </div>

    {%- if section.settings.subheading != blank -%}
      <p class="mk-muted">{{ section.settings.subheading | escape }}</p>
    {%- endif -%}

    <div style="margin: 1.6rem 0 2.4rem;">
      <input
        class="mk-search-input"
        type="search"
        placeholder="{{ section.settings.search_placeholder | escape }}"
        aria-label="{{ section.settings.search_placeholder | escape }}"
        data-mk-input
      >
    </div>

    <div class="mk-character-grid">
      {%- for t in tags -%}
        {%- assign label_slug = t | remove: character_prefix -%}
        {%- assign label = label_slug | replace: '-', ' ' -%}
        <a
          class="mk-character-card"
          href="{{ section.settings.base_collection_url }}/{{ t | handleize }}"
          data-mk-item
          data-mk-text="{{ label | escape }}"
        >
          <span class="mk-character-card__label">{{ label | capitalize }}</span>
        </a>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "MK characters",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Fallback heading",
      "default": "Characters"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Search and browse all characters."
    },
    {
      "type": "text",
      "id": "search_placeholder",
      "label": "Search placeholder",
      "default": "Search characters..."
    },
    {
      "type": "text",
      "id": "tag_prefix",
      "label": "Character tag prefix",
      "default": "character:"
    },
    {
      "type": "text",
      "id": "base_collection_url",
      "label": "Result base URL",
      "default": "/collections/all"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "MK characters"
    }
  ]
}
{% endschema %}

