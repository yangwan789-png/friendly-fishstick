<section class="series-filter">
  <style>
    .series-filter {
      padding: 32px 0;
      background: var(--color-bg);
      border-bottom: 1px solid var(--color-border);
    }

    .series-filter .container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .series-filter__title {
      font-size: 1rem;
      font-weight: 600;
      color: var(--color-text-subdued);
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 16px;
    }

    .series-filter__list {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
    }

    .series-filter__item {
      padding: 10px 20px;
      background: var(--color-bg-card);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-full);
      font-size: 13px;
      font-weight: 500;
      color: var(--color-text);
      cursor: pointer;
      transition: all 0.3s ease;
      white-space: nowrap;
      text-decoration: none;
      display: inline-block;
    }

    .series-filter__item:hover {
      border-color: var(--color-primary);
      color: var(--color-primary);
    }

    .series-filter__item.active {
      background: linear-gradient(135deg, var(--color-primary), var(--color-accent));
      border-color: transparent;
      color: white;
      box-shadow: var(--shadow-glow);
    }

    @media (max-width: 768px) {
      .series-filter {
        padding: 24px 0;
      }

      .series-filter .container {
        padding: 0 16px;
      }

      .series-filter__item {
        padding: 8px 16px;
        font-size: 12px;
      }
    }
  </style>

  <div class="container">
    <h3 class="series-filter__title">Product Series</h3>
    <div class="series-filter__list">
      <a href="/collections/all" class="series-filter__item {% if collection.handle == 'all' or template.name == 'list-collections' %}active{% endif %}">All Series</a>
      {% for col in collections.all %}
        {% if col.handle != 'all' %}
          <a href="{{ col.url }}" class="series-filter__item {% if collection.handle == col.handle %}active{% endif %}">{{ col.title }}</a>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Series Filter",
  "settings": []
}
{% endschema %}
