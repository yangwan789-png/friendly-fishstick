<section class="real-displays-section">
  <style>
    .real-displays-section {
      padding: 80px 0;
      position: relative;
      background: linear-gradient(180deg, var(--color-bg) 0%, #0d0d14 100%);
    }

    .real-displays-section::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--color-border), transparent);
    }

    .displays-container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .section-header {
      text-align: center;
      margin-bottom: 64px;
    }

    .section-title {
      font-size: clamp(2rem, 5vw, 3.5rem);
      margin-bottom: 16px;
    }

    .section-title span {
      background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .section-subtitle {
      font-size: 1.125rem;
      color: var(--color-text-subdued);
      max-width: 600px;
      margin: 0 auto 24px;
    }

    .frame-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 24px;
      background: linear-gradient(135deg, rgba(255, 42, 109, 0.15), rgba(5, 217, 232, 0.15));
      border: 1px solid rgba(255, 42, 109, 0.3);
      border-radius: var(--radius-full);
      font-size: 14px;
      font-weight: 600;
      color: var(--color-primary);
      text-transform: uppercase;
      letter-spacing: 1px;
      animation: pulse 3s ease-in-out infinite;
    }

    .frame-badge svg {
      width: 18px;
      height: 18px;
      fill: var(--color-primary);
    }

    .frame-showcase {
      display: flex;
      flex-direction: column;
      align-items: center;
      margin-bottom: 64px;
    }

    .frame-showcase-label {
      font-size: 12px;
      font-weight: 600;
      color: var(--color-primary);
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-bottom: 20px;
    }

    .frame-showcase-container {
      position: relative;
      max-width: 600px;
      width: 100%;
      border-radius: var(--radius-xl);
      overflow: hidden;
      box-shadow: var(--shadow-lg), var(--shadow-glow);
      transition: transform 0.5s ease;
    }

    .frame-showcase-container:hover {
      transform: translateY(-4px);
    }

    .frame-showcase-image {
      width: 100%;
      height: auto;
      display: block;
    }

    .frame-showcase-overlay {
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      padding: 32px;
      background: linear-gradient(to top, rgba(0, 0, 0, 0.9), transparent);
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
    }

    .frame-showcase-title {
      font-size: 1.5rem;
      font-weight: 700;
      color: white;
    }

    .frame-showcase-badge {
      padding: 8px 16px;
      background: var(--color-primary);
      border-radius: var(--radius-full);
      font-size: 12px;
      font-weight: 600;
      color: white;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .product-displays-label {
      font-size: 12px;
      font-weight: 600;
      color: var(--color-primary);
      text-transform: uppercase;
      letter-spacing: 2px;
      text-align: center;
      margin-bottom: 32px;
    }

    .product-displays-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-bottom: 64px;
    }

    .product-display-card {
      position: relative;
      border-radius: var(--radius-xl);
      overflow: hidden;
      background: var(--color-bg-card);
      transition: all 0.4s ease;
    }

    .product-display-card:hover {
      transform: translateY(-8px);
      box-shadow: var(--shadow-lg), var(--shadow-glow);
    }

    .product-display-media-wrapper {
      position: relative;
      overflow: hidden;
    }

    .product-display-image {
      width: 100%;
      height: auto;
      display: block;
      transition: transform 0.5s ease;
    }

    .product-display-video {
      width: 100%;
      height: auto;
      display: block;
      transition: transform 0.5s ease;
    }

    .product-display-card:hover .product-display-image,
    .product-display-card:hover .product-display-video {
      transform: scale(1.05);
    }

    .product-display-play-btn {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 64px;
      height: 64px;
      background: rgba(255, 255, 255, 0.2);
      backdrop-filter: blur(10px);
      border: 2px solid white;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.3s ease;
      z-index: 10;
    }

    .product-display-play-btn:hover {
      background: rgba(255, 255, 255, 0.3);
      transform: translate(-50%, -50%) scale(1.1);
    }

    .product-display-play-btn svg {
      width: 24px;
      height: 24px;
      fill: white;
      margin-left: 4px;
    }

    .product-display-badge {
      position: absolute;
      top: 16px;
      left: 16px;
      padding: 6px 12px;
      background: rgba(0, 0, 0, 0.8);
      backdrop-filter: blur(10px);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-full);
      font-size: 11px;
      font-weight: 600;
      color: var(--color-primary);
      text-transform: uppercase;
      letter-spacing: 1px;
      z-index: 10;
    }

    .product-display-info {
      padding: 20px;
      text-align: center;
    }

    .product-display-title {
      font-size: 14px;
      font-weight: 600;
      color: var(--color-text);
      margin-bottom: 4px;
    }

    .product-display-location {
      font-size: 12px;
      color: var(--color-text-subdued);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .displays-cta {
      text-align: center;
    }

    .displays-cta p {
      font-size: 1.125rem;
      color: var(--color-text-subdued);
      margin-bottom: 24px;
    }

    @media (max-width: 1024px) {
      .product-displays-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 768px) {
      .real-displays-section {
        padding: 60px 0;
      }

      .product-displays-grid {
        grid-template-columns: 1fr;
        gap: 16px;
      }

      .frame-showcase-overlay {
        padding: 20px;
      }

      .frame-showcase-title {
        font-size: 1.125rem;
      }
    }
  </style>

  <div class="displays-container">
    <div class="section-header">
      <h2 class="section-title">Real <span>Displays</span></h2>
      <p class="section-subtitle">See how our art prints look in real spaces. Every order includes a FREE premium frame.</p>
      <div class="frame-badge">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M20 19V5c0-1.1-.9-2-2-2H6c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2zM6 5h12v14H6V5zm2 3h8v2H8V8zm0 4h8v2H8v-2zm0 4h8v2H8v-2z"/>
        </svg>
        FREE Premium Frame Included
      </div>
    </div>

    {% if section.blocks.size > 0 %}
      {% assign frame_block = section.blocks | where: 'type', 'frame_showcase' | first %}
      {% assign product_blocks = section.blocks | where: 'type', 'product_display' %}

      {% if frame_block %}
        <div class="frame-showcase">
          <span class="frame-showcase-label">Included Frame</span>
          <div class="frame-showcase-container">
            <img src="{{ frame_block.settings.image | img_url: 'master' }}" alt="{{ frame_block.settings.title | escape }}" class="frame-showcase-image">
            <div class="frame-showcase-overlay">
              <span class="frame-showcase-title">{{ frame_block.settings.title }}</span>
              <span class="frame-showcase-badge">Free Gift</span>
            </div>
          </div>
        </div>
      {% endif %}

      {% if product_blocks.size > 0 %}
        <span class="product-displays-label">Customer Displays</span>
        <div class="product-displays-grid">
          {% for block in product_blocks %}
            {% if block.settings.image %}
              <div class="product-display-card">
                <div class="product-display-media-wrapper">
                  {% if block.settings.video %}
                    <video 
                      src="{{ block.settings.video.sources[0].url }}" 
                      class="product-display-video"
                      poster="{{ block.settings.image | img_url: 'master' }}"
                      loop 
                      muted 
                      playsinline
                      controlslist="nodownload"
                      preload="metadata"
                    >
                      <source src="{{ block.settings.video.sources[0].url }}" type="video/mp4">
                    </video>
                    <div class="product-display-play-btn" onclick="this.parentElement.querySelector('video').play(); this.style.display='none';">
                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                        <path d="M8 5v14l11-7z"/>
                      </svg>
                    </div>
                  {% else %}
                    <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.title | escape }}" class="product-display-image">
                  {% endif %}
                  <span class="product-display-badge">{{ block.settings.badge }}</span>
                </div>
                <div class="product-display-info">
                  <span class="product-display-title">{{ block.settings.title }}</span>
                  <span class="product-display-location">{{ block.settings.location }}</span>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      {% endif %}
    {% else %}
      <div class="frame-showcase">
        <span class="frame-showcase-label">Included Frame</span>
        <div class="frame-showcase-container">
          <img src="https://neeko-copilot.bytedance.net/api/text_to_image?prompt=black%20picture%20frame%20modern%20minimalist%20design%20professional%20product%20photography%20white%20background&image_size=landscape_4_3" alt="Premium Frame" class="frame-showcase-image">
          <div class="frame-showcase-overlay">
            <span class="frame-showcase-title">Premium Frame</span>
            <span class="frame-showcase-badge">Free Gift</span>
          </div>
        </div>
      </div>

      <span class="product-displays-label">Customer Displays</span>
      <div class="product-displays-grid">
        <div class="product-display-card">
          <div class="product-display-image-wrapper">
            <img src="https://neeko-copilot.bytedance.net/api/text_to_image?prompt=anime%20art%20print%20framed%20on%20bedroom%20wall%20realistic%20customer%20photo&image_size=portrait_4_3" alt="Display 1" class="product-display-image">
            <span class="product-display-badge">Customer Photo</span>
          </div>
          <div class="product-display-info">
            <span class="product-display-title">Bedroom Decor</span>
            <span class="product-display-location">Tokyo, Japan</span>
          </div>
        </div>
        <div class="product-display-card">
          <div class="product-display-image-wrapper">
            <img src="https://neeko-copilot.bytedance.net/api/text_to_image?prompt=anime%20art%20print%20framed%20on%20living%20room%20wall%20realistic%20customer%20photo&image_size=portrait_4_3" alt="Display 2" class="product-display-image">
            <span class="product-display-badge">Customer Photo</span>
          </div>
          <div class="product-display-info">
            <span class="product-display-title">Living Room</span>
            <span class="product-display-location">New York, USA</span>
          </div>
        </div>
        <div class="product-display-card">
          <div class="product-display-image-wrapper">
            <img src="https://neeko-copilot.bytedance.net/api/text_to_image?prompt=anime%20art%20print%20framed%20on%20game%20room%20wall%20realistic%20customer%20photo&image_size=portrait_4_3" alt="Display 3" class="product-display-image">
            <span class="product-display-badge">Customer Photo</span>
          </div>
          <div class="product-display-info">
            <span class="product-display-title">Game Room</span>
            <span class="product-display-location">London, UK</span>
          </div>
        </div>
      </div>
    {% endif %}

    <div class="displays-cta">
      <p>Get your favorite anime art print with a FREE premium frame today!</p>
      <a href="/collections/all" class="btn btn-primary">Explore Collection</a>
    </div>
  </div>

  {% schema %}
    {
      "name": "Real Displays",
      "settings": [
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "See how our art prints look in real spaces. Every order includes a FREE premium frame."
        }
      ],
      "blocks": [
        {
          "type": "frame_showcase",
          "name": "Frame Showcase",
          "limit": 1,
          "settings": [
            {
              "type": "image_picker",
              "id": "image",
              "label": "Frame Image"
            },
            {
              "type": "text",
              "id": "title",
              "label": "Frame Title",
              "default": "Premium Frame"
            }
          ]
        },
        {
          "type": "product_display",
          "name": "Product Display",
          "settings": [
            {
              "type": "image_picker",
              "id": "image",
              "label": "Product Image"
            },
            {
              "type": "video",
              "id": "video",
              "label": "Display Video"
            },
            {
              "type": "text",
              "id": "title",
              "label": "Display Title",
              "default": "Display Item"
            },
            {
              "type": "text",
              "id": "location",
              "label": "Location",
              "default": "Customer Home"
            },
            {
              "type": "text",
              "id": "badge",
              "label": "Badge Text",
              "default": "Customer Video"
            }
          ]
        }
      ]
    }
  {% endschema %}
</section>