<section class="featured-section">
  <div class="container">
    <div class="section-header">
      <p class="section-header__subtitle">Featured</p>
      <h2 class="section-header__title">Popular Art Prints</h2>
      <p class="section-header__description">Our most popular anime art prints loved by fans</p>
    </div>
    <div class="featured-grid">
      {% for product in collections.all.products limit: 8 %}
        <a href="{{ product.url }}" class="product-card">
          <div class="product-card__image-wrapper">
            <img src="{{ product.featured_image.src | img_url: 'large' }}" alt="{{ product.title }}" class="product-card__image">
            {% if product.tags contains 'New' %}
              <span class="product-card__badge new">New</span>
            {% endif %}
            {% if product.compare_at_price > product.price %}
              <span class="product-card__badge sale">Sale</span>
            {% endif %}
          </div>
          <div class="product-card__content">
            <span class="product-card__category">{{ product.collections.first.title }}</span>
            <h3 class="product-card__title">{{ product.title }}</h3>
            <div class="product-card__price">
              {{ product.price | money }}
              {% if product.compare_at_price > product.price %}
                <span class="product-card__original-price">{{ product.compare_at_price | money }}</span>
              {% endif %}
            </div>
          </div>
          <button class="product-card__quick-add" aria-label="Add to cart">+</button>
        </a>
      {% endfor %}
    </div>
    <div class="text-center mt-8">
      <a href="/collections/all" class="btn btn-secondary">View All Products</a>
    </div>
  </div>
</section>
{% schema %}
{
  "name": "Featured Products",
  "settings": []
}
{% endschema %}