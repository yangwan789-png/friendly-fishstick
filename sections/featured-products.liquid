<section class="gallery-section">
  <style>
    .gallery-section {
      padding: 80px 0;
      position: relative;
      background: linear-gradient(180deg, var(--color-bg) 0%, #0d0d14 100%);
    }

    .gallery-section::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 1px;
      background: linear-gradient(90deg, transparent, var(--color-border), transparent);
    }

    .gallery-container {
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 24px;
    }

    .section-header {
      text-align: center;
      margin-bottom: 64px;
    }

    .section-title {
      font-size: clamp(2rem, 5vw, 3.5rem);
      margin-bottom: 16px;
    }

    .section-title span {
      background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .section-subtitle {
      font-size: 1.125rem;
      color: var(--color-text-subdued);
      max-width: 600px;
      margin: 0 auto 24px;
    }

    .frame-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 24px;
      background: linear-gradient(135deg, rgba(255, 42, 109, 0.15), rgba(5, 217, 232, 0.15));
      border: 1px solid rgba(255, 42, 109, 0.3);
      border-radius: var(--radius-full);
      font-size: 14px;
      font-weight: 600;
      color: var(--color-primary);
      text-transform: uppercase;
      letter-spacing: 1px;
      animation: pulse 3s ease-in-out infinite;
    }

    .frame-badge svg {
      width: 18px;
      height: 18px;
      fill: var(--color-primary);
    }

    .gallery-highlight {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 32px;
      margin-bottom: 64px;
      align-items: center;
    }

    .highlight-image-wrapper {
      position: relative;
      border-radius: var(--radius-xl);
      overflow: hidden;
      box-shadow: var(--shadow-lg), var(--shadow-glow);
    }

    .highlight-image {
      width: 100%;
      height: auto;
      display: block;
    }

    .highlight-badge {
      position: absolute;
      top: 20px;
      left: 20px;
      padding: 8px 16px;
      background: rgba(0, 0, 0, 0.8);
      backdrop-filter: blur(10px);
      border: 1px solid var(--color-primary);
      border-radius: var(--radius-full);
      font-size: 12px;
      font-weight: 600;
      color: var(--color-primary);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .highlight-info {
      padding: 24px 0;
    }

    .highlight-title {
      font-size: clamp(1.5rem, 3vw, 2.5rem);
      font-weight: 800;
      margin-bottom: 16px;
      line-height: 1.2;
    }

    .highlight-title span {
      background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .highlight-description {
      font-size: 1.125rem;
      color: var(--color-text-subdued);
      line-height: 1.8;
      margin-bottom: 24px;
    }

    .frame-features {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
      margin-bottom: 32px;
    }

    .frame-feature {
      display: flex;
      align-items: flex-start;
      gap: 12px;
      padding: 16px;
      background: rgba(255, 255, 255, 0.03);
      border-radius: var(--radius-lg);
      border: 1px solid var(--color-border);
    }

    .frame-feature-icon {
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, var(--color-primary), var(--color-secondary));
      border-radius: var(--radius-md);
      flex-shrink: 0;
    }

    .frame-feature-icon svg {
      width: 16px;
      height: 16px;
      fill: white;
    }

    .frame-feature-text {
      font-size: 14px;
      color: var(--color-text);
    }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 20px;
    }

    .gallery-item {
      position: relative;
      border-radius: var(--radius-xl);
      overflow: hidden;
      cursor: pointer;
      transition: all 0.4s ease;
      background: var(--color-bg-card);
    }

    .gallery-item:hover {
      transform: translateY(-8px);
      box-shadow: var(--shadow-lg), var(--shadow-glow);
    }

    .gallery-item:nth-child(1) { grid-row: span 2; }
    .gallery-item:nth-child(3) { grid-row: span 2; }
    .gallery-item:nth-child(5) { grid-row: span 2; }

    .gallery-image {
      width: 100%;
      height: auto;
      display: block;
      transition: transform 0.5s ease;
    }

    .gallery-item:hover .gallery-image {
      transform: scale(1.05);
    }

    .gallery-overlay {
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(to top, rgba(0, 0, 0, 0.9), transparent);
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      padding: 20px;
      opacity: 0;
      transition: opacity 0.3s ease;
    }

    .gallery-item:hover .gallery-overlay {
      opacity: 1;
    }

    .gallery-item-title {
      font-size: 14px;
      font-weight: 600;
      color: white;
      margin-bottom: 4px;
    }

    .gallery-item-location {
      font-size: 12px;
      color: var(--color-primary);
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .gallery-cta {
      text-align: center;
      margin-top: 64px;
    }

    .gallery-cta p {
      font-size: 1.125rem;
      color: var(--color-text-subdued);
      margin-bottom: 24px;
    }

    @media (max-width: 1024px) {
      .gallery-highlight {
        grid-template-columns: 1fr;
        gap: 24px;
      }

      .gallery-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .gallery-item:nth-child(1),
      .gallery-item:nth-child(3),
      .gallery-item:nth-child(5) {
        grid-row: span 1;
      }
    }

    @media (max-width: 768px) {
      .gallery-section {
        padding: 60px 0;
      }

      .gallery-grid {
        grid-template-columns: 1fr;
        gap: 16px;
      }

      .frame-features {
        grid-template-columns: 1fr;
      }

      .highlight-info {
        padding: 16px 0;
      }
    }
  </style>

  <div class="gallery-container">
    <div class="section-header">
      <h2 class="section-title">Real <span>Displays</span></h2>
      <p class="section-subtitle">See how our art prints look in real spaces. Every order includes a FREE premium frame.</p>
      <div class="frame-badge">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M20 19V5c0-1.1-.9-2-2-2H6c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2zM6 5h12v14H6V5zm2 3h8v2H8V8zm0 4h8v2H8v-2zm0 4h8v2H8v-2z"/>
        </svg>
        FREE Premium Frame Included
      </div>
    </div>

    <div class="gallery-highlight">
      <div class="highlight-image-wrapper">
        <img src="https://neeko-copilot.bytedance.net/api/text_to_image?prompt=anime%20art%20print%20framed%20on%20wall%20realistic%20interior%20living%20room%20decoration%20professional%20photography&image_size=landscape_4_3" alt="Featured Gallery" class="highlight-image">
        <span class="highlight-badge">Best Selling</span>
      </div>
      <div class="highlight-info">
        <h3 class="highlight-title">Transform Your <span>Space</span></h3>
        <p class="highlight-description">Our premium art prints come ready to hang with a complimentary frame. Each piece is carefully crafted with high-quality materials to ensure lasting quality.</p>
        <div class="frame-features">
          <div class="frame-feature">
            <div class="frame-feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M20 19V5c0-1.1-.9-2-2-2H6c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h12c1.1 0 2-.9 2-2zM6 5h12v14H6V5zm2 3h8v2H8V8zm0 4h8v2H8v-2zm0 4h8v2H8v-2z"/>
              </svg>
            </div>
            <span class="frame-feature-text">Free Frame Included</span>
          </div>
          <div class="frame-feature">
            <div class="frame-feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
              </svg>
            </div>
            <span class="frame-feature-text">Protective Glass</span>
          </div>
          <div class="frame-feature">
            <div class="frame-feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm0 16H5V5h14v14zM7 13h5v5H7zm7-5h5v5h-5zm0 5h5v5h-5z"/>
              </svg>
            </div>
            <span class="frame-feature-text">Ready to Hang</span>
          </div>
          <div class="frame-feature">
            <div class="frame-feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M12 2L4.5 20.29l.71.71L12 18l6.79 3 .71-.71z"/>
              </svg>
            </div>
            <span class="frame-feature-text">High Quality</span>
          </div>
        </div>
      </div>
    </div>

    <div class="gallery-grid">
      {% for block in section.blocks %}
        {% if block.settings.image %}
          <div class="gallery-item">
            <img src="{{ block.settings.image | img_url: 'master' }}" alt="{{ block.settings.title | escape }}" class="gallery-image">
            <div class="gallery-overlay">
              <span class="gallery-item-title">{{ block.settings.title }}</span>
              <span class="gallery-item-location">{{ block.settings.location }}</span>
            </div>
          </div>
        {% endif %}
      {% endfor %}
      {% if section.blocks.size == 0 %}
        <div class="gallery-item">
          <img src="https://neeko-copilot.bytedance.net/api/text_to_image?prompt=naruto%20anime%20art%20print%20framed%20on%20bedroom%20wall%20realistic%20photo&image_size=portrait_4_3" alt="Gallery 1" class="gallery-image">
          <div class="gallery-overlay">
            <span class="gallery-item-title">Naruto Collection</span>
            <span class="gallery-item-location">Tokyo, Japan</span>
          </div>
        </div>
        <div class="gallery-item">
          <img src="https://neeko-copilot.bytedance.net/api/text_to_image?prompt=one%20piece%20anime%20art%20print%20framed%20on%20living%20room%20wall%20realistic%20photo&image_size=landscape_16_9" alt="Gallery 2" class="gallery-image">
          <div class="gallery-overlay">
            <span class="gallery-item-title">One Piece Wall</span>
            <span class="gallery-item-location">New York, USA</span>
          </div>
        </div>
        <div class="gallery-item">
          <img src="https://neeko-copilot.bytedance.net/api/text_to_image?prompt=dragon%20ball%20anime%20art%20print%20framed%20on%20game%20room%20wall%20realistic%20photo&image_size=portrait_4_3" alt="Gallery 3" class="gallery-image">
          <div class="gallery-overlay">
            <span class="gallery-item-title">Dragon Ball Setup</span>
            <span class="gallery-item-location">London, UK</span>
          </div>
        </div>
        <div class="gallery-item">
          <img src="https://neeko-copilot.bytedance.net/api/text_to_image?prompt=marvel%20superhero%20art%20print%20framed%20on%20office%20wall%20realistic%20photo&image_size=landscape_16_9" alt="Gallery 4" class="gallery-image">
          <div class="gallery-overlay">
            <span class="gallery-item-title">Marvel Office</span>
            <span class="gallery-item-location">Paris, France</span>
          </div>
        </div>
        <div class="gallery-item">
          <img src="https://neeko-copilot.bytedance.net/api/text_to_image?prompt=anime%20art%20collection%20multiple%20prints%20framed%20on%20wall%20realistic%20photo&image_size=portrait_4_3" alt="Gallery 5" class="gallery-image">
          <div class="gallery-overlay">
            <span class="gallery-item-title">Ultimate Collection</span>
            <span class="gallery-item-location">Sydney, Australia</span>
          </div>
        </div>
        <div class="gallery-item">
          <img src="https://neeko-copilot.bytedance.net/api/text_to_image?prompt=anime%20art%20print%20framed%20on%20study%20room%20wall%20realistic%20photo&image_size=landscape_16_9" alt="Gallery 6" class="gallery-image">
          <div class="gallery-overlay">
            <span class="gallery-item-title">Study Room</span>
            <span class="gallery-item-location">Seoul, Korea</span>
          </div>
        </div>
      {% endif %}
    </div>

    <div class="gallery-cta">
      <p>Get your favorite anime art print with a FREE premium frame today!</p>
      <a href="/collections/all" class="btn btn-primary">Explore Collection</a>
    </div>
  </div>

  {% schema %}
    {
      "name": "Customer Gallery",
      "settings": [
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "See how our art prints look in real homes. Every order includes a FREE premium frame."
        }
      ],
      "blocks": [
        {
          "type": "gallery_image",
          "name": "Gallery Image",
          "settings": [
            {
              "type": "image_picker",
              "id": "image",
              "label": "Image"
            },
            {
              "type": "text",
              "id": "title",
              "label": "Title",
              "default": "Gallery Item"
            },
            {
              "type": "text",
              "id": "location",
              "label": "Location",
              "default": "Customer Home"
            }
          ]
        }
      ]
    }
  {% endschema %}
</section>