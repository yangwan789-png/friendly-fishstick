<section class="collection-list">
  {% if section.settings.heading != blank %}
    <h2>{{ section.settings.heading }}</h2>
  {% endif %}
  <div class="collection-list__grid">
    {% for collection in collections %}
      <a href="{{ collection.url }}" class="collection-list__item">
        {% if collection.featured_image %}
          {{ collection.featured_image | image_url: width: 400 | image_tag: alt: collection.title }}
        {% endif %}
        <h3>{{ collection.title }}</h3>
      </a>
    {% endfor %}
  </div>
</section>
{% schema %}
{
  "name": "Collection list",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Collections"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "Dark"
    }
  ]
}
{% endschema %}