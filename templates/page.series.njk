{% layout 'theme' %}

<div class="series-page">
  <div class="collection-banner">
    <div class="container">
      {% if page.title == 'Naruto' %}
        <h1>Naruto</h1>
        <p>Discover stunning art prints featuring your favorite Naruto characters. From the Hidden Leaf Village to epic battles, find the perfect piece for your collection.</p>
        <p class="collection-banner__count">5 Characters Available</p>
      {% elsif page.title == 'One Piece' %}
        <h1>One Piece</h1>
        <p>Set sail with the Straw Hat Pirates! Explore our One Piece art print collection featuring Luffy and his crew on their adventure.</p>
        <p class="collection-banner__count">5 Characters Available</p>
      {% elsif page.title == 'Dragon Ball' %}
        <h1>Dragon Ball</h1>
        <p>Power up your space with Dragon Ball art prints! From Goku's epic transformations to legendary battles.</p>
        <p class="collection-banner__count">5 Characters Available</p>
      {% elsif page.title == 'Marvel' %}
        <h1>Marvel</h1>
        <p>Assemble your dream collection with Marvel art prints! Featuring iconic superheroes from the Avengers.</p>
        <p class="collection-banner__count">5 Characters Available</p>
      {% else %}
        <h1>{{ page.title }}</h1>
        <p>{{ page.content }}</p>
      {% endif %}
    </div>
  </div>

  <section class="series-filter">
    <div class="container">
      <h3 class="series-filter__title">Product Series</h3>
      <div class="series-filter__list">
        <a href="/collections/all" class="series-filter__item">All Series</a>
        <a href="/pages/naruto" class="series-filter__item {% if page.title == 'Naruto' %}active{% endif %}">Naruto</a>
        <a href="/pages/one-piece" class="series-filter__item {% if page.title == 'One Piece' %}active{% endif %}">One Piece</a>
        <a href="/pages/dragon-ball" class="series-filter__item {% if page.title == 'Dragon Ball' %}active{% endif %}">Dragon Ball</a>
        <a href="/pages/marvel" class="series-filter__item {% if page.title == 'Marvel' %}active{% endif %}">Marvel</a>
      </div>
    </div>
  </section>

  <section class="collection-products">
    <div class="product-grid">
      {% assign product_count = 6 %}
      {% for i in (1..product_count) %}
        <a href="/products/{{ page.handle }}-product-{{ i }}" class="product-card" data-character="" data-style="anime">
          <div class="product-card__image-wrapper">
            <img src="https://trae-api-cn.mchost.guru/api/ide/v1/text_to_image?prompt={{ page.title | url_encode }}%20anime%20character%20art%20print%20poster%20high%20quality&image_size=portrait_4_3" alt="{{ page.title }} product {{ i }}" class="product-card__image">
            <span class="product-card__badge new">New</span>
          </div>
          <div class="product-card__content">
            <span class="product-card__category">{{ page.title }}</span>
            <h3 class="product-card__title">{{ page.title }} Character Art #{{ i }}</h3>
            <div class="product-card__price">$29.99</div>
          </div>
          <button class="product-card__quick-add" aria-label="Add to cart">+</button>
        </a>
      {% endfor %}
    </div>
  </section>
</div>